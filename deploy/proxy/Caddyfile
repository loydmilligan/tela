{
	servers {
		# With trusted_proxies set, Caddy strips any X-Forwarded-For entries it
		# cannot vouch for and writes a single trustworthy hop — the client IP
		# from Caddy's own listener. The backend's clientIPForRateLimit reads
		# the RIGHTMOST entry, so this pairs to deny client-supplied XFF spoofs.
		trusted_proxies static private_ranges
	}
}

:80 {
	handle /api/* {
		reverse_proxy backend:8080
	}

	handle /ws/* {
		reverse_proxy backend:8080
	}

	handle /p/* {
		reverse_proxy backend:8080
	}

	# M15.5 PublicShare OG bot-gate: bot UAs hitting /share/* go to the
	# backend (writes an OG envelope); real browsers fall through to the
	# frontend SPA (M15.1 share-mode UI). The named matcher must precede
	# the catch-all /share/* handle — Caddy resolves handles by first match.
	#
	# Mirror of botUASubstrings in backend/internal/api/public_share.go —
	# keep in sync.
	@share_bots {
		path /share/*
		header_regexp User-Agent "(?i)(slackbot-linkexpanding|twitterbot|facebookexternalhit|discordbot|telegrambot|linkedinbot|whatsapp|bot/|bot\s)"
	}
	handle @share_bots {
		reverse_proxy backend:8080
	}
	handle /share/* {
		reverse_proxy frontend:80
	}

	# ── Marketing landing (standalone Astro static, served at the apex) ──────
	# The landing (landing/dist, mounted read-only at /srv/landing) owns the
	# apex "/" and its build assets under /_astro/*. Everything else falls
	# through to the app SPA below. The app's own "/" route is CLIENT-SIDE only
	# (TanStack Router redirects to the user's space in-browser), so a hard load
	# of "/" lands on this marketing page while in-app navigation is unaffected.
	# App build assets live under /assets/* (Vite), landing under /_astro/* —
	# no collision. These handles MUST precede the catch-all (Caddy resolves
	# handles in source order).
	handle /_astro/* {
		root * /srv/landing
		file_server
	}
	@landing_apex path / /index.html
	handle @landing_apex {
		root * /srv/landing
		rewrite * /index.html
		file_server
	}

	# App SPA (everything not matched above: /login, /spaces/*, /settings, …).
	handle {
		reverse_proxy frontend:80
	}
}
