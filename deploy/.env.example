# Copy to deploy/.env and fill in real values. Loaded automatically by
# docker compose (same directory as the compose file).
#
# Generate TELA_SHARE_SECRET / TELA_API_KEY_SECRET with: openssl rand -hex 32
# Do NOT regenerate either on subsequent deploys — TELA_SHARE_SECRET
# invalidates outstanding share password cookies; TELA_API_KEY_SECRET
# invalidates every existing personal access token (PAT).

TELA_PUBLIC_BASE_URL=https://your-deploy-host.example.com
TELA_SHARE_SECRET=replace-me-with-openssl-rand-hex-32
TELA_API_KEY_SECRET=replace-me-with-openssl-rand-hex-32

# Org custom domains (white-label front doors, e.g. tela.ngss.io). Fully
# dynamic + multi-org: orgs self-register hostnames at runtime and Caddy
# on-demand-issues each cert — no per-domain config. Requires DIRECT-TLS mode:
# set TELA_SITE_ADDRESS to the canonical host and publish 80+443 on the proxy
# (see docker-compose.yml). Behind Cloudflare this does NOT work (CF terminates
# TLS, so on-demand never fires).
#   TELA_SITE_ADDRESS — canonical host Caddy binds (e.g. telawiki.com). Empty
#     → :80 (terminator/CF mode), which disables custom domains.
#   TELA_CUSTOM_DOMAIN_TARGET — the ONE shared box address every org subdomain
#     points at (CNAME). Not per-org; it's just your ingress. Optional —
#     defaults to the canonical host (so admins CNAME → telawiki.com, or
#     A-record straight to the box IP). Set a dedicated record like
#     connect.telawiki.com → A → box IP if you want the IP to move freely.
# See docs/custom-domains.md.
# TELA_SITE_ADDRESS=telawiki.com
# TELA_CUSTOM_DOMAIN_TARGET=connect.telawiki.com

# Postgres. The bundled compose stack runs a `pgvector/pgvector:pg17` service (Postgres 17 + the pgvector extension RAG needs) and
# constructs TELA_DATABASE_URL from these for the backend (host = the compose
# service name `postgres`). TELA_PG_USER / TELA_PG_DB default to `tela` if unset;
# TELA_PG_PASSWORD has NO default and MUST be set — leaving it blank yields a
# passwordless DB and a broken DSN. Generate one with: openssl rand -hex 24
# Changing user/db/password after first boot needs a matching DB reset
# (`make reset-prod-db`) — the data volume is initialized once with these values.
TELA_PG_USER=tela
TELA_PG_PASSWORD=replace-me-with-a-strong-password
TELA_PG_DB=tela

# TELA_DATABASE_URL — the Postgres DSN the backend reads. In the bundled compose
# stack it is AUTO-CONSTRUCTED from the TELA_PG_* vars above, so you do NOT set it
# here. Set it explicitly ONLY when running the backend outside this compose
# stack (bare process, external/managed Postgres). Format:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=disable
# Use sslmode=require (or verify-full) when the DB is reached over an untrusted
# network rather than a private container link.
# TELA_DATABASE_URL=postgres://tela:PASSWORD@postgres:5432/tela?sslmode=disable

# Bootstrap admin (OPTIONAL). On first boot (empty users table) tela creates one
# instance-admin ONLY when TELA_ADMIN_PASSWORD is set. Leave it unset and the
# first admin is created through the web setup wizard at /setup instead (the
# fresh instance lands there automatically). TELA_ADMIN_EMAIL is optional — when
# set, the admin row is created with a pre-confirmed email so it's exempt from
# the email-confirmation gate and can log in by email; setting it later
# backfills the existing admin.
# TELA_ADMIN_USERNAME=admin
# TELA_ADMIN_PASSWORD=                 # unset → use the /setup web wizard instead
# TELA_ADMIN_EMAIL=admin@example.com

# Registration policy. By default anyone can register (open self-registration).
# For a private/internal instance, close it via the admin API after setup:
#   PATCH /api/admin/settings  {"settings":{"registration_open":"false"}}
# There is no env var for this — it is a runtime setting changed through the
# admin UI (Settings → Instance) or the API.

# Transactional email (self-registration confirm + password reset) AND
# notification emails (@-mention, comment reply, added-to-space, followed-page
# update, new page in a followed space — opt-out, per-user in Settings →
# Notifications). When TELA_SMTP_HOST is
# UNSET, tela logs the email + link to stdout instead of sending (fine for dev /
# first boot), so notification emails are log-only until set. Works
# with any SMTP relay — e.g. Resend: host smtp.resend.com, user "resend",
# password = your Resend API key, from any verified address.
# TELA_SMTP_HOST=smtp.resend.com
# TELA_SMTP_PORT=587                   # 587 starttls (default) | 465 ssl
# TELA_SMTP_TLS=starttls               # starttls | ssl | none
# TELA_SMTP_USERNAME=resend
# TELA_SMTP_PASSWORD=your-smtp-password-or-api-key
# TELA_SMTP_FROM=tela <tela@example.com>

# ---- ntfy push channel (optional) ----------------------------------------
# The third notification channel beside in-app + email: pushes to an ntfy
# (https://ntfy.sh) topic, so events reach a phone/desktop with a tap-through
# deep link to the page. Per-user, opt-out, per event type in Settings →
# Notifications; each user sets their own topic on their profile (empty topic =
# channel off for them). When TELA_NTFY_URL is UNSET the whole channel is inert
# (no pushes), exactly like unset SMTP. Point it at ntfy.sh or your self-hosted
# ntfy server. TELA_NTFY_TOKEN is only needed for access-protected topics.
# TELA_NTFY_URL=https://ntfy.sh
# TELA_NTFY_TOKEN=tk_your-ntfy-access-token

# #3 PDF export (gotenberg). Both default sensibly for the bundled compose
# stack; override only if you run gotenberg elsewhere or the proxy service is
# named differently. TELA_GOTENBERG_URL = where the backend POSTs render jobs;
# TELA_PDF_RENDER_BASE_URL = the INTERNAL origin gotenberg's Chromium loads the
# reader from (keep it internal so PDF generation skips the CDN).
# TELA_GOTENBERG_URL=http://gotenberg:3000
# TELA_PDF_RENDER_BASE_URL=http://proxy

# Deck render sidecar (deck/ in the repo). Slidev markdown → PNG/PDF/PPTX and
# the live interactive SPA served at /api/pages/{id}/deck/spa/{path...}.
# Override only if the sidecar runs outside the bundled compose stack (e.g. on
# a remote host). Default http://deck:3344 (the compose service name). The MCP
# deploy-deck target bumps only this sidecar (slidev-theme-tahta bump fast-path).
# TELA_DECK_URL=http://deck:3344

# Self-serve billing (Polar — polar.sh, merchant of record). Ships DARK: with
# TELA_POLAR_TOKEN / TELA_POLAR_WEBHOOK_SECRET unset, the checkout + portal
# endpoints 503 and plans stay operator-assigned (PATCH /api/admin/plan). Enable:
#   1. Create products+prices in the Polar dashboard for the paid tiers (Plus,
#      Team); note each product's UUID.
#   2. Create an Organization Access Token (scopes: checkouts:write,
#      customer_sessions:write, products:read, subscriptions:read, orders:read).
#   3. Add a webhook endpoint → <PUBLIC_BASE_URL>/api/billing/webhook (Raw
#      format); copy its signing secret verbatim (no whsec_ prefix to strip).
#   4. Map plan keys → product UUIDs in TELA_POLAR_PRODUCTS.
# Test against the sandbox first (base URL below + sandbox token/secret/products).
# Full setup + reconciliation model in docs/billing.md.
# TELA_POLAR_TOKEN=polar_oat_xxxxx
# TELA_POLAR_WEBHOOK_SECRET=your-webhook-signing-secret
# TELA_POLAR_BASE_URL=https://api.polar.sh        # or https://sandbox-api.polar.sh
# TELA_POLAR_PRODUCTS=personal_plus:<product-uuid>,org_team:<product-uuid>

# RAG semantic retrieval (internal/rag). The feature ships DARK: with
# TELA_RAG_EMBED_URL unset, /api/rag/* return 503 and no embeddings are
# computed. Point it at an Ollama server to enable hybrid chunk search; the
# embedder is pluggable (Ollama is the only backend today). EMBED_DIM is
# advisory — the page_chunks.embedding column is fixed at vector(1024), so a
# model with a different dimension needs a new migration.
#
# Self-host option: bring up the bundled Ollama with `docker compose
# --profile embed up -d`, set the URL to the compose service below, and pull the
# model: `docker compose exec ollama ollama pull qwen3-embedding:0.6b`.
# TELA_RAG_EMBED_URL=http://ollama:11434
#
# The model MUST be 1024-d (the page_chunks.embedding column is fixed at
# vector(1024)); qwen3-embedding:0.6b is 1024-d and is the code default.
# TELA_RAG_EMBED_MODEL=qwen3-embedding:0.6b
# TELA_RAG_EMBED_DIM=1024
#
# Query-side instruction prefix for ASYMMETRIC retrieval. Qwen3-Embedding embeds
# a query as "Instruct: {task}\nQuery:{q}" and a passage bare; this is the {task}.
# Leave unset for the sensible default. Set to a single space to DISABLE the
# prefix entirely (e.g. for a non-instruction model like mxbai-embed-large).
# Changing it affects only NEW queries — no re-embed needed.
# TELA_RAG_QUERY_INSTRUCT=Given a question, retrieve passages from the knowledge base that answer it
#
# Optional cross-encoder RERANKER (second-stage precision; see docs/rag.md). Off
# unless set. URL is the FULL /rerank endpoint of a Cohere/Jina-compatible server
# (also works with TEI/Infinity/vLLM rerank). Validate any rollout with rag-eval.
# TELA_RAG_RERANK_URL=http://reranker:8080/rerank
# TELA_RAG_RERANK_MODEL=
# TELA_RAG_RERANK_TOKEN=
#
# Knowledge gaps log each "ask your docs" question to surface what the corpus
# couldn't answer (admin-only to read). Set to 0 to disable logging entirely.
# TELA_RAG_LOG_ASKS=1
#
# Fair-use rate limit (per ACCOUNT, per minute) on the synchronous embed paths —
# semantic search / research / suggest-links / ask — so one client can't saturate
# the shared embedder. Default 30/min; raise it if your embedder has headroom,
# or set <=0 to disable the throttle entirely.
# TELA_EMBED_RATE_LIMIT=30
#
# Managed option (tela cloud): instead of running your own embedder, point at
# tela cloud's managed endpoint and authenticate with a telawiki.com PAT.
# Requires a plan that includes managed semantic search. Keep the model name
# matched to the cloud's (qwen3-embedding:0.6b, 1024-d) so the chunk hash + dim
# stay consistent.
# TELA_RAG_EMBED_URL=https://telawiki.com/api/cloud/ollama
# TELA_RAG_EMBED_TOKEN=tela_pat_xxxxxxxx

# Managed AI / "ask your docs" (internal/llm). Sibling to RAG: ships DARK with
# TELA_LLM_URL unset (/api/rag/ask returns 503; the managed proxy 503s). The
# client speaks the OpenAI-compatible /chat/completions shape, so the URL is the
# provider base INCLUDING its /v1 (Ollama serves this at {host}/v1). Used
# in-process by /api/rag/ask (retrieve top chunks → grounded prompt → answer +
# cited sources) and exposed to self-hosters via the managed proxy below.
# TELA_LLM_URL=http://ollama:11434/v1
# TELA_LLM_MODEL=qwen2.5:7b
# Caps the answer length (completion max_tokens). Default 4096 — room for long
# tables/enumerations and atlas page drafts without truncation (the relief
# proxy's generous per-request timeout accommodates the generation time).
# Set 0 (or -1) to disable the cap; lower it if you want tighter worst-case latency.
# TELA_LLM_MAX_TOKENS=4096
#
# Foreground concurrency gate (ask/assist): caps simultaneous completions on the
# primary so a burst degrades gracefully instead of collapsing throughput, then
# spills the overflow to a relief layer at genuine saturation. Background work
# (summarize/agreement) bypasses the gate and never spills. Default 20 (sized to a
# healthy local-model batch); 0 disables the gate. OVERFLOW_MODEL is the spill
# target — set it to the relief proxy's auto-registered `tela-chat-overflow` alias
# (→ L2); unset = no spill (a full gate just queues on the primary). OVERFLOW_WAIT
# is how long a request waits for a primary slot before spilling (default 12s).
# TELA_LLM_MAX_INFLIGHT=20
# TELA_LLM_OVERFLOW_MODEL=tela-chat-overflow
# TELA_LLM_OVERFLOW_WAIT_MS=12000
#
# Answers stream token-by-token to the web UI over SSE (POST /api/rag/ask/stream);
# the blocking JSON POST /api/rag/ask stays for MCP + non-web clients. No config.
#
# Managed option (tela cloud): instead of running your own model, point at tela
# cloud's managed LLM endpoint and authenticate with a telawiki.com PAT.
# Requires a plan that includes managed AI (the ask_docs feature). The endpoint
# speaks the same OpenAI shape, so it's a drop-in for the URL above.
# TELA_LLM_URL=https://telawiki.com/api/cloud/llm/v1
# TELA_LLM_TOKEN=tela_pat_xxxxxxxx

# ── AI relief proxy (chat failover chain) ───────────────────────────────────
# Optional LiteLLM proxy in front of chat. The `litellm` service is profile-gated;
# turn it on with COMPOSE_PROFILES and point tela at it:
# COMPOSE_PROFILES=relief
# LITELLM_MASTER_KEY=choose-a-strong-secret      # tela presents this as its bearer
# TELA_LLM_URL=http://litellm:4000/v1
# TELA_LLM_MODEL=<same as TELA_LLM_1_MODEL>      # tela calls the chain by L1's name
# TELA_LLM_TOKEN=${LITELLM_MASTER_KEY}
# TELA_RAG_EMBED_URL=http://litellm:4000/v1      # embed also rides the proxy (single)
# TELA_RAG_EMBED_MODEL=<same as TELA_EMBED_PRIMARY_MODEL>
# TELA_RAG_EMBED_TOKEN=${LITELLM_MASTER_KEY}
# TELA_AI_RELIEF=1                               # admin card shows "relief pool"
#
# CHAT is an ordered failover CHAIN: L1 → L2 → L3. A request hits L1; if L1 is
# erroring / cooled-down / times out, LiteLLM cascades to L2, then L3 — so a layer
# going DOWN never cuts off service. LiteLLM fallbacks are FAILURE-based, not
# load-based: OVERLOAD (L1 healthy but saturated) is handled in the backend by the
# foreground gate above (TELA_LLM_MAX_INFLIGHT), which spills to the auto-registered
# `tela-chat-overflow` alias (→ L2). So "down" spills here; "overloaded" spills via
# the backend — both land on L2. Each api_base is an OpenAI-compatible base; _KEY is
# its key or "none"; _PROVIDER defaults to "openai". Enumerate layers contiguously
# from 1; leave L3 blank to run a 2-layer chain.
# TELA_LLM_1_URL=http://ollama:11434/v1         # primary (local)
# TELA_LLM_1_MODEL=qwen2.5:7b
# TELA_LLM_1_KEY=none
# TELA_LLM_1_MAX_PARALLEL=0                      # optional concurrency cap (0=off)
# TELA_LLM_2_URL=http://host:11438/v1           # e.g. a subscription-backed Claude wrapper
# TELA_LLM_2_MODEL=sonnet
# TELA_LLM_2_KEY=none
# TELA_LLM_3_URL=https://api.groq.com/openai/v1 # final backstop (elastic cloud)
# TELA_LLM_3_MODEL=llama-3.3-70b-versatile
# TELA_LLM_3_KEY=gsk_...
# Tuning (optional):
# TELA_AI_NUM_RETRIES=1        # same-layer retries before moving to the next layer
# TELA_AI_ALLOWED_FAILS=2      # failures before a layer is cooled down
# TELA_AI_COOLDOWN=30          # seconds a cooled-down layer sits out
# TELA_AI_TIMEOUT=900          # per-request timeout (s); generous so a slow model's
#                              # long draft completes on L1 instead of failing over
#
# Embeddings stay SINGLE — a relief embedder must be the SAME 1024-d model on a
# second host (different-dim vectors aren't interchangeable in page_chunks), so
# there's no embed chain here.
# TELA_EMBED_PRIMARY_URL=http://ollama:11434/v1
# TELA_EMBED_PRIMARY_MODEL=qwen3-embedding:0.6b
# TELA_EMBED_PRIMARY_KEY=none
#
# Expose LiteLLM's /metrics for an off-box Prometheus (per-layer requests, state,
# cooldowns — the data to ALARM on when traffic spills to L2/L3). Default
# loopback-only; set to a tailnet IP:port to scrape from another host. Scrape
# path is /metrics/ with the master key as a Bearer.
# LITELLM_METRICS_BIND=127.0.0.1:4000

# Optional: deep-link the admin "AI endpoints & reliability" card (Settings →
# Insights) to your Grafana failover dashboard. Unset → no link shown.
# TELA_GRAFANA_AI_URL=https://grafana.example.com/d/tela-ai

# Epistemic trust pass (internal/agreement). Runs automatically whenever both
# the LLM and embedder are configured: for each page it scores nearest same-space
# pages as corroborate / contradict / unrelated and records the tally in
# page_agreement. Ships ON; set TELA_AGREEMENT=0 to disable without turning off
# your LLM — the escape hatch when the extra per-page LLM cost is unwanted on a
# self-hosted instance.
# TELA_AGREEMENT=1

# Atlas concurrent-run cap (internal/api/atlas.go). Atlas doc-gen runs and
# interactive ask/research share one LLM endpoint; a higher value can overwhelm
# it. Raise only with a beefier endpoint or a dedicated LLM for Atlas.
# Default 1. ATLAS_LLM_CONCURRENCY is the per-client concurrency gate inside
# each run (default 6); TELA_ATLAS_WORKDIR is where it unpacks working files
# (default: OS temp dir).
# TELA_ATLAS_MAX_CONCURRENT_RUNS=1
# ATLAS_LLM_CONCURRENCY=6
# TELA_ATLAS_WORKDIR=

# Deck image generation (internal/api/imagegen.go). Powers the MCP
# generate_deck_image tool so deck authors can generate on-brand imagery (tahta
# ships the recipe + treat step but never generates). Ships DARK with
# TELA_IMAGE_GEN_URL unset (the tool 503s); also honours the ai.disabled
# kill-switch. OpenAI-compatible Images endpoint (POST {url}/images/generations →
# {data:[{b64_json}]}), so the URL is the provider base INCLUDING /v1. From a
# Docker backend reach a private-overlay box by its IP, not its name (RAG-embed
# gotcha). Generation can take ~20s (FLUX, few steps) to minutes (heavier models).
# TELA_IMAGE_GEN_URL=http://100.x.x.x:11437/v1
# TELA_IMAGE_GEN_MODEL=flux2-klein-4b
# TELA_IMAGE_GEN_KEY=

# MCP OAuth (Phase 5). The MCP endpoint (/api/mcp) ships PAT-only and DARK for
# OAuth: with TELA_WORKOS_ISSUER unset, no OAuth is advertised, the Protected
# Resource Metadata endpoint 404s, and only tela PATs authenticate. Set these to
# let Claude.ai / ChatGPT "Connect" via WorkOS AuthKit (Standalone bridge):
#   TELA_WORKOS_ISSUER  — your AuthKit domain, e.g. https://your-app.authkit.app
#                         (JWKS is fetched at {issuer}/oauth2/jwks; tokens' iss
#                         must match this and aud must match TELA_MCP_RESOURCE).
#   TELA_MCP_RESOURCE   — this MCP endpoint's public URL, the OAuth audience.
#                         Defaults to {TELA_PUBLIC_BASE_URL}/api/mcp.
#   WORKOS_API_KEY      — server-side secret, used ONLY for the Standalone
#                         oauth2/complete call (the 5b login bridge). Never sent
#                         to clients.
# TELA_WORKOS_ISSUER=https://your-app.authkit.app
# TELA_MCP_RESOURCE=https://your-deploy-host.example.com/api/mcp
# WORKOS_API_KEY=sk_...

# Federated sign-in (social login). Each provider is independent and DARK until
# both of its vars are set — an unset provider simply shows no button on the
# login screen. Register the redirect/callback URL with each provider as
# https://<your-host>/api/auth/sso/<provider>/callback (google|microsoft|github).
# Google + Microsoft are OIDC; GitHub is OAuth2 (identity read from its API).
# Per-org enterprise SSO (OIDC) is configured at runtime by an instance admin
# (PUT /api/orgs/{id}/sso), not here — its callback is /api/auth/sso/org/callback.
# TELA_SSO_GOOGLE_CLIENT_ID=
# TELA_SSO_GOOGLE_CLIENT_SECRET=
# TELA_SSO_MICROSOFT_CLIENT_ID=
# TELA_SSO_MICROSOFT_CLIENT_SECRET=
# TELA_SSO_GITHUB_CLIENT_ID=
# TELA_SSO_GITHUB_CLIENT_SECRET=

# Optional build-time metadata surfaced by GET /api/version (M16.A.1.5).
# Consumed by the MCP server (M16.B.1) for a startup compat check. Leave
# unset for `dev` / `unknown` defaults; set in CI / release scripts:
#   TELA_VERSION=v0.4.2
#   TELA_COMMIT=$(git rev-parse --short HEAD)
# TELA_VERSION=dev
# TELA_COMMIT=unknown

# Split-topology image refs (docker-compose.split.yml). `make deploy` injects
# these per-deploy (pinned to the commit), so you normally DON'T set them here —
# the compose defaults already point at the on-box registry. Set them only to run
# `docker compose -f docker-compose.split.yml up` by hand, or to pin a specific
# tag / a different registry. TELA_PULL_POLICY=never is what `make deploy-offline`
# uses so the bare docker-loaded images are taken as-is. See docs/deploy.md.
# TELA_BACKEND_IMAGE=127.0.0.1:5000/tela-backend:latest
# TELA_FRONTEND_IMAGE=127.0.0.1:5000/tela-frontend:latest
# TELA_PULL_POLICY=always

# WebDAV sync surface (/dav/ — see docs/webdav-sync.md). Default ON (PAT-gated,
# scope-checked). All optional; empty/unset = default.
#   TELA_WEBDAV_ENABLED — set 0/false/off/no to disable the whole surface.
#   TELA_WEBDAV_CREATE_SPACES — set 0/false/off/no to stop root-level MKCOL
#     from minting new spaces (space creation stays in-app only). Security note:
#     defaults ON, meaning any write-scoped PAT can create spaces via WebDAV.
#   TELA_WEBDAV_DELETE_FLOOR / TELA_WEBDAV_DELETE_FRACTION — mass-delete guard
#     tuning (see dav_delete_guard.go).
#   TELA_WEBDAV_FILE_MAX_BYTES — per-file upload cap for space files.
# TELA_WEBDAV_ENABLED=
# TELA_WEBDAV_CREATE_SPACES=
# TELA_WEBDAV_DELETE_FLOOR=
# TELA_WEBDAV_DELETE_FRACTION=
# TELA_WEBDAV_FILE_MAX_BYTES=

# Umami analytics (docker-compose.split.yml). Self-hosted privacy-friendly
# analytics for the landing page (https://umami.is). Generate both with:
#   openssl rand -hex 32
# UMAMI_APP_SECRET is the internal signing secret for Umami sessions.
# UMAMI_DB_PASSWORD is the password for Umami's own Postgres (separate from tela's).
UMAMI_APP_SECRET=replace-me-with-openssl-rand-hex-32
UMAMI_DB_PASSWORD=replace-me-with-a-strong-password

# Ops knobs (all optional; empty/unset = default).
#   TELA_ADDR — override the backend listen address (default :8080). Useful
#     when running the backend as a bare process outside Docker.
#   TELA_LOG_FORMAT=json — structured logs (default: text).
#   TELA_API_KEY_AUDIT_DAYS — PAT audit-log retention in days.
#   TELA_EVENTS_RETENTION_DAYS — activity-feed events GC window (default 180
#     days). High-volume types (page.view, api.request) are pruned on this
#     schedule; access_audit rows are kept forever as the canonical access trail.
#   TELA_DISABLE_WELCOME_SEED — any value skips seeding the welcome space on
#     first boot.
# TELA_ADDR=:8080
# TELA_LOG_FORMAT=
# TELA_API_KEY_AUDIT_DAYS=
# TELA_EVENTS_RETENTION_DAYS=180
# TELA_DISABLE_WELCOME_SEED=
