{
  "name": "tela-mcp",
  "version": "0.4.0",
  "description": "MCP server for Tela — exposes spaces, pages, search, and backlinks to MCP-capable agents (Claude Code, etc.) over stdio.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tela-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "semver": "^7.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.8",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
