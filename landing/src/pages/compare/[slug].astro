---
// /compare/<slug> — one honest comparison page per competitor, data-driven from
// src/data/compare.ts. Mirrors the /mcp page: Prose layout + per-page TechArticle
// + BreadcrumbList JSON-LD. Token-only styles (the landing-gate enforces it).
import Prose from '../../layouts/Prose.astro';
import { competitors } from '../../data/compare';
import type { Competitor } from '../../data/compare';

export function getStaticPaths() {
  return competitors.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props as { c: Competitor };
const url = `https://telawiki.com/compare/${c.slug}/`;
---

<Prose
  title={c.seoTitle}
  description={c.metaDescription}
  kicker="Compare"
  heading={c.heading}
  updated="June 30, 2026"
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'TechArticle',
        '@id': `${url}#article`,
        headline: c.heading,
        description: c.metaDescription,
        url,
        inLanguage: 'en',
        dateModified: '2026-06-30',
        author: { '@id': 'https://telawiki.com/#org' },
        publisher: { '@id': 'https://telawiki.com/#org' },
        about: { '@id': 'https://telawiki.com/#software' },
        isPartOf: { '@id': 'https://telawiki.com/#website' },
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://telawiki.com/' },
          { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://telawiki.com/compare/' },
          { '@type': 'ListItem', position: 3, name: `tela vs ${c.name}`, item: url },
        ],
      },
    ],
  })} />

  <p class="lead">{c.lead}</p>

  <h2>tela vs {c.name}, at a glance</h2>
  <div class="cmp-scroll">
    <table class="cmp">
      <caption class="sr-only">A feature comparison of tela and {c.name}.</caption>
      <thead>
        <tr>
          <th scope="col">Feature</th>
          <th scope="col" class="is-tela">tela</th>
          <th scope="col">{c.name}</th>
        </tr>
      </thead>
      <tbody>
        {c.rows.map((r) => (
          <tr>
            <th scope="row">{r.feature}</th>
            <td class="is-tela" data-label="tela">{r.tela}</td>
            <td data-label={c.name}>{r.them}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Why teams switch to tela</h2>
  <ul>
    {c.whySwitch.map((w) => <li>{w}</li>)}
  </ul>

  <h2>When {c.name} is the better choice</h2>
  <p>{c.whenBetter}</p>

  <h2>Try tela</h2>
  <p>
    tela is an open-source (AGPL), self-hostable team wiki. Self-host it, or start
    on the free cloud tier at <a href="/">telawiki.com</a>. See the
    <a href="/mcp/">MCP server docs</a> for connecting your agents, or
    <a href="/compare/">compare tela with other tools</a>.
  </p>

  <p class="source">{c.source} tela facts current as of June 2026.</p>
</Prose>

<style>
  /* Token-only: colors via var(--*), spacing on the 4px grid (rem), like Prose. */
  .cmp-scroll {
    overflow-x: auto;
    margin: 1.5rem 0 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .cmp {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .cmp caption.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .cmp th,
  .cmp td {
    text-align: left;
    vertical-align: top;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cmp thead th {
    color: var(--fg);
    font-weight: 600;
    background: var(--surface-sunk);
    white-space: nowrap;
  }
  .cmp tbody th[scope='row'] {
    color: var(--fg);
    font-weight: 600;
    width: 12rem;
  }
  .cmp td { color: var(--fg-soft); }
  .cmp tbody tr:last-child th,
  .cmp tbody tr:last-child td { border-bottom: 0; }
  /* tela's column is the earned highlight. */
  .cmp .is-tela { background: var(--surface); }
  .cmp thead th.is-tela { color: var(--brand-strong); }

  .source {
    margin-top: 2.5rem;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }
</style>
