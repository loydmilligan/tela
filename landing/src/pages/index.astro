---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import AgentWeave from '../components/AgentWeave.astro';
import Retrieval from '../components/Retrieval.astro';
import AskDocs from '../components/AskDocs.astro';
import Pivot from '../components/Pivot.astro';
import EditorShowcase from '../components/EditorShowcase.astro';
import ShowcaseBento from '../components/ShowcaseBento.astro';
import Compare from '../components/Compare.astro';
import Security from '../components/Security.astro';
import Publish from '../components/Publish.astro';
import Decks from '../components/Decks.astro';
import Pricing from '../components/Pricing.astro';
import Credibility from '../components/Credibility.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base ogDescription="A markdown team wiki with semantic search and a built-in MCP server. Your AI agents search your docs by meaning and read, write, and cite them — right inside Claude and ChatGPT. Real-time multiplayer, SSO, scoped access. Your markdown, hosted or self-hosted.">
  <SiteHeader />
  <main id="main">
    <Hero />
    <AgentWeave />
    <Retrieval />
    <AskDocs />
    <Pivot />
    <EditorShowcase />
    <ShowcaseBento />
    <Compare />
    <Security />
    <Publish />
    <Decks />
    <Pricing />
    <Credibility />
    <Faq />
    <FinalCta />
  </main>
  <SiteFooter />
</Base>
