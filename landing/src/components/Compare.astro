---
// §5 — Honest comparison, as a table. Not a green-tick parity matrix and not a
// wiki-parity scorecard: tela has moved past "another wiki" — it documents
// itself (Atlas) and your agents work it from Claude/ChatGPT. So each row
// centers that category difference AND concedes the one thing the alternative
// still does better. Stacks into labelled blocks on mobile.
// `slug` links the row to its full /compare/<slug> page (omitted where there's
// no single page, e.g. the "AI wikis" category row).
const rows = [
  { n: 'Notion', slug: 'notion', edge: 'Your docs write themselves — point Atlas at a repo or Jira project and it generates a cited, coverage-checked wiki — over plain markdown you own, that your agents read and write from Claude and ChatGPT. Not a closed block store with a chat sidebar bolted on.', better: 'Databases, templates, and all-round polish are years ahead. Want a relational workspace, not a wiki? Use Notion.' },
  { n: 'Confluence', slug: 'confluence', edge: 'Atlas turns a git repo or a Jira project into a cited, coverage-checked wiki and keeps it fresh; agents search and write it by meaning; and it\'s portable markdown you can run yourself — no enterprise install, no per-seat pricing.', better: 'Deep two-way Jira workflow integration (tela documents from Jira; it doesn\'t drive Jira), granular permissions, and governance at thousand-user scale. Atlassian shops have reasons to stay.' },
  { n: 'Obsidian', slug: 'obsidian', edge: 'Built for a team and for agents: Atlas-written docs, semantic retrieval, live multiplayer, SSO and roles, and an MCP connector — not a single-player vault you sync by hand.', better: 'Local-first single-user is its whole point; the plugin library and graph view are unmatched. Solo? Hard to beat.' },
  { n: 'Notion AI / “AI” wikis', edge: 'tela generates the wiki from your sources and scores its coverage, then lets your own agent retrieve and write it from Claude or ChatGPT, over markdown you can export — a chatbot bolted onto a wiki does neither, and only works inside their app.', better: 'One-vendor convenience and a polished in-app assistant, with no embedder to think about. If you only want their chatbot, it\'s simpler.' },
  { n: 'GitBook', slug: 'gitbook', edge: 'Atlas generates and keeps cited docs current from your repo automatically; an MCP server so Claude can search and write pages natively; and fully self-hostable under AGPL with plain markdown output you control.', better: 'Developer-doc polish and multi-version publication for open-source libraries are its strong suit. Public-facing product docs with a clean public URL? GitBook is hard to beat.' },
  { n: 'Outline', slug: 'outline', edge: 'Atlas turns a git repo or Jira project into a cited, coverage-checked wiki and keeps it fresh automatically; semantic search and ask-your-docs with paragraph citations; and an MCP server so agents are first-class team members alongside humans.', better: 'A polished, well-maintained self-hosted wiki with a strong community and a clean UI. If you want a great self-hosted wiki without AI generation, Outline is excellent.' },
];
---
<section id="compare" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Compare</p>
    <h2 class="h2">Not just another wiki.</h2>
    <p class="lede">tela documents itself and your agents work it from Claude and ChatGPT — so the honest question isn't “which wiki,” it's how it differs from each tool you'd otherwise reach for, and the one thing each still does better.</p>
  </div>

  <div class="cmp-wrap reveal-up">
    <table class="cmp">
      <thead>
        <tr>
          <th scope="col" class="col-name">Versus</th>
          <th scope="col" class="col-edge">Where tela wins</th>
          <th scope="col" class="col-better">What it still does better</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <th scope="row" class="cmp-name">
              {r.n}
              {r.slug && <a class="cmp-more" href={`/compare/${r.slug}/`}>Full comparison →</a>}
            </th>
            <td class="cmp-edge" data-label="Where tela wins">
              <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{r.edge}</span>
            </td>
            <td class="cmp-better" data-label="It still does better">{r.better}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="synth reveal-up">
    None of them close the loop tela does: your sources become a cited, coverage-checked wiki,
    your agents reason over and maintain it from Claude and ChatGPT, and it's all plain markdown
    you own — with real-time editing, SSO, roles, and an audit trail.
  </p>
</section>

<style>
  .cmp-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
  }
  .cmp {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .cmp thead th {
    text-align: left;
    padding: 0.85rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    background: var(--surface-sunk);
    border-bottom: 1px solid var(--border);
    vertical-align: bottom;
  }
  .cmp thead .col-edge { color: var(--brand); }
  .cmp thead .col-name,
  .cmp thead .col-better { color: var(--fg-faint); }

  .cmp tbody tr { border-bottom: 1px solid var(--border); }
  .cmp tbody tr:last-child { border-bottom: 0; }
  .cmp td,
  .cmp tbody th { padding: 1rem 1.1rem; vertical-align: top; text-align: left; }

  .cmp-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--fg);
    width: 18%;
    min-width: 8rem;
  }
  .cmp-more {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--brand);
    text-decoration: none;
  }
  .cmp-more:hover { color: var(--brand-strong); text-decoration: underline; }
  .cmp-edge {
    color: var(--fg);
    width: 45%;
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
  }
  .cmp-edge span { display: inline; }
  .cmp-edge .tick {
    color: var(--brand);
    display: inline-block;
    vertical-align: -2px;
    margin-right: 0.35rem;
  }
  .cmp-better { color: var(--fg-faint); width: 37%; }

  .synth {
    margin-top: 1.75rem;
    max-width: 64ch;
    margin-inline: auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--fg-soft);
    letter-spacing: var(--tracking-tight);
  }
  .synth strong { color: var(--fg); font-weight: 600; }

  /* ── Mobile: stack each row into a labelled block ─────────────────────── */
  @media (max-width: 720px) {
    .cmp-wrap { border: 0; background: transparent; overflow: visible; }
    .cmp thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip-path: inset(50%); }
    .cmp, .cmp tbody, .cmp tr, .cmp td, .cmp tbody th { display: block; width: auto; }
    .cmp tr {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      background: var(--surface);
      margin-bottom: 0.85rem;
      overflow: hidden;
    }
    .cmp-name {
      font-size: var(--text-lg);
      padding: 0.9rem 1.1rem 0.6rem;
      border-bottom: 1px solid var(--border);
      min-width: 0;
    }
    .cmp-edge, .cmp-better { border: 0; }
    .cmp td::before {
      content: attr(data-label);
      display: block;
      margin-bottom: 0.3rem;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .cmp-edge::before { color: var(--brand); }
    .cmp-better::before { color: var(--fg-faint); }
  }
</style>
