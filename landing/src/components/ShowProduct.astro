---
// §7 — Show the product. Headline + capability bullets beside the editor mock.
import EditorMock from './EditorMock.astro';
const bullets = [
  'Spaces with nested pages',
  'WYSIWYG markdown editing',
  'Page history + one-click revisions',
  'Public share links, optionally password-gated',
  'Excalidraw diagrams inline',
  'Role-based access per space',
];
---
<section class="section">
  <div class="grid">
    <div class="copy reveal-up">
      <p class="kicker"><span class="kicker-dot"></span>The product</p>
      <h2 class="h2">A fast wiki the humans actually want to use.</h2>
      <p class="lede">Spaces with nested pages. WYSIWYG markdown editing. Page history with one-click revisions. Public share links with optional password gating. Excalidraw diagrams inline. Role-based access per space.</p>
      <ul class="bullets">
        {bullets.map((b) => (
          <li>
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            {b}
          </li>
        ))}
      </ul>
    </div>
    <div class="art reveal-up">
      <EditorMock />
    </div>
  </div>
</section>

<style>
  .grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  .bullets {
    margin-top: 1.8rem;
    display: grid;
    gap: 0.7rem;
  }
  .bullets li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fg-soft);
    font-size: var(--text-base);
  }
  .bullets svg { color: var(--brand); flex: none; }
  @media (min-width: 960px) {
    .grid { grid-template-columns: 0.85fr 1.15fr; gap: 3.5rem; }
  }
</style>
