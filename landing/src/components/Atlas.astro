---
// Atlas — the "documents itself" half of the loop and the opening beat of the AI
// act. Point Atlas at a source (a git repo or a Jira project); it reads the
// source, drafts cited pages, publishes them as ordinary tela pages, and keeps
// them fresh. The STAR detail is the coverage panel: docs measured against a
// deterministic spine, with named gaps and file:line citations — measurably
// complete, not "the AI wrote something". Visuals are real-feeling, never lorem,
// never a fake-integration logo wall (git + Jira only). No JSON on the surface.

// connect-a-source flow — three real steps
const steps = [
  {
    n: '1',
    t: 'Point it at a source',
    d: 'A git repo (public, or private with a token) or a Jira project. Optional branch, subpath, include/exclude globs.',
    code: 'git · jira',
  },
  {
    n: '2',
    t: 'It reads and writes',
    d: 'Atlas extracts the real surface — routes, flags, env vars, models, state — then drafts grounded, cited pages and publishes the tree.',
    code: 'spine → draft → publish',
  },
  {
    n: '3',
    t: 'It stays current',
    d: 'A cheap probe checks for drift about every 15 minutes; on your schedule it regenerates only the sources that actually changed.',
    code: 'hourly · daily · weekly',
  },
];

// the named gaps the coverage audit reports (kind · name · file:line) — a short,
// real-feeling slice of an uncovered surface for a deploy service.
const gaps = [
  { kind: 'route', name: 'POST /deploy/rollback', loc: 'handlers/deploy.go:212' },
  { kind: 'env', name: 'DEPLOY_CANARY_PCT', loc: 'config/env.go:48' },
];

// citation chips resolved to file:line, as they appear inline in a generated page.
const cites = ['handlers/deploy.go:64', 'cmd/deployd/main.go:30'];
---

<section id="atlas" class="atlas" data-reveal-root>
  <div class="head reveal-up">
    <p class="eyebrow"><span class="eyebrow-dot"></span>Atlas · documents itself</p>
    <h2 class="title">Where do all these docs come from?</h2>
    <p class="lede">
      <strong>Atlas writes them.</strong> Point Atlas at a source — a git repo or a Jira project —
      and it reads the source, plans a wiki structure, drafts cited markdown pages, and publishes
      them into a space as ordinary tela pages. Then it watches the source and regenerates when it
      moves ahead. The pages are real tela pages — searchable, shareable, revisioned — the same wiki
      your agents reason over.
    </p>
  </div>

  <!-- the loop, shown: a source → a generated, cited page → a coverage score -->
  <div class="stage reveal-up">
    <!-- source -->
    <figure class="src">
      <figcaption class="src-kind"><span class="src-tag git">git</span> source</figcaption>
      <p class="src-loc">github.com/acme/deploy-svc</p>
      <div class="src-chips">
        <span class="chip">branch <b>main</b></span>
        <span class="chip">subpath <b>/cmd</b></span>
      </div>
      <p class="src-fresh"><span class="fresh-dot"></span>behind upstream → regenerated 2h ago</p>
    </figure>

    <span class="flow-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
    </span>

    <!-- generated page (real-feeling cited markdown) -->
    <figure class="page">
      <figcaption class="page-top">
        <span class="page-crumb">Engineering / Deploy surface</span>
        <span class="page-badge"><span class="badge-glyph">✳</span>Atlas · generated</span>
      </figcaption>
      <div class="page-body">
        <p class="p-h">Deploy surface</p>
        <p class="p-line">
          The <code>deployd</code> service exposes the rollout API and reads its
          tunables from the environment.<sup class="cite">{cites[0]}</sup>
        </p>
        <p class="p-line">
          <code>POST /deploy</code> starts a rollout; the daemon boots from
          <code>cmd/deployd</code>.<sup class="cite">{cites[1]}</sup>
        </p>
      </div>
    </figure>
  </div>

  <!-- THE STAR: coverage, measured against the spine -->
  <div class="coverage reveal-up">
    <div class="cov-score">
      <div class="cov-ring" data-cov style="--pct:92" role="img" aria-label="coverage 92 percent">
        <span class="cov-num">92<span class="cov-pct">%</span></span>
      </div>
      <p class="cov-label">surface coverage</p>
      <p class="cov-sub">covered against a deterministic spine — routes, flags, env vars, models, state — every citation resolved to <code>file:line</code>.</p>
    </div>
    <div class="cov-gaps">
      <p class="gaps-label">Named gaps — what the docs don't cover yet</p>
      <ul class="gaps-list">
        {gaps.map((g) => (
          <li class="gap">
            <span class="gap-kind">{g.kind}</span>
            <code class="gap-name">{g.name}</code>
            <code class="gap-loc">{g.loc}</code>
          </li>
        ))}
      </ul>
      <p class="gaps-note">Measurably complete — not "the AI wrote something". Atlas regenerates the gaps until coverage clears your threshold.</p>
    </div>
  </div>

  <!-- connect a source: three real steps -->
  <ol class="steps reveal-up">
    {steps.map((s) => (
      <li class="step">
        <span class="step-n">{s.n}</span>
        <div class="step-body">
          <h3 class="step-t">{s.t}</h3>
          <p class="step-d">{s.d}</p>
          <code class="step-code">{s.code}</code>
        </div>
      </li>
    ))}
  </ol>

  <!-- supporting truths: credentials + the MCP loop tie-in -->
  <div class="notes reveal-up">
    <div class="note">
      <p class="note-t">Your tokens stay yours</p>
      <p class="note-d">
        git and Jira tokens are named, reusable credentials owned by a user or an org — write-only
        over the API, never written to a page or a log. Lend a private-repo token to an org project
        without putting it in a shared pool; nothing's left behind if you leave.
      </p>
    </div>
    <div class="note">
      <p class="note-t">In the loop with your agents</p>
      <p class="note-d">
        Atlas is reachable over MCP, too — <code>atlas_list_projects</code>, <code>atlas_run</code>,
        <code>atlas_run_status</code> let an agent in Claude or ChatGPT kick off and check a run, not
        just read the result.
      </p>
    </div>
  </div>

  <p class="honesty reveal-up">
    Two source types today — <strong>git and Jira</strong>. More are coming. We name what Atlas reads
    rather than imply a catalog it doesn't have. Atlas needs an LLM endpoint and an embedder — both on
    for the hosted instance; self-hosting, you point it at your own.
  </p>

  <a class="more" href="https://tela.cagdas.io/tela/docs">See how Atlas works →</a>
</section>

<style>
  .atlas {
    max-width: var(--col-max);
    margin-inline: auto;
    padding: var(--section-y) var(--space-gutter);
    scroll-margin-top: 5rem;
  }

  .head { max-width: 48rem; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-kicker);
    color: var(--brand);
    margin-bottom: 1rem;
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--brand); box-shadow: var(--glow-brand); }
  .title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-snug);
    color: var(--fg);
  }
  .lede {
    margin-top: 1.1rem;
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: var(--measure);
    line-height: var(--leading-normal);
  }
  .lede strong { color: var(--fg); font-weight: 600; }

  /* the shown loop: source → generated page */
  .stage {
    margin-top: 2.75rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: stretch;
  }
  .flow-arrow {
    display: grid;
    place-items: center;
    color: var(--fg-faint);
    transform: rotate(90deg);
  }

  .src, .page {
    margin: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-card);
  }

  /* source card */
  .src { padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .src-kind {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-faint);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .src-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.12rem 0.45rem;
    border-radius: var(--radius-xs);
    border: 1px solid var(--pill-border);
    background: var(--brand-wash);
    color: var(--brand);
    text-transform: none;
    letter-spacing: 0;
  }
  .src-loc {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    word-break: break-all;
  }
  .src-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.2rem 0.5rem;
  }
  .chip b { color: var(--fg); font-weight: 600; }
  .src-fresh {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: var(--text-xs);
    color: var(--accent);
    margin-top: 0.1rem;
  }
  .fresh-dot {
    width: 6px; height: 6px;
    border-radius: var(--radius-full);
    background: var(--live-dot);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 22%, transparent);
    flex: none;
  }

  /* generated page card */
  .page { overflow: hidden; display: flex; flex-direction: column; }
  .page-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    height: 38px;
    padding: 0 0.9rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-sunk);
  }
  .page-crumb { font-size: var(--text-xs); color: var(--fg-faint); }
  .page-badge {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--brand);
    border: 1px solid var(--pill-border);
    background: var(--brand-wash);
    border-radius: var(--radius-full);
    padding: 0.15rem 0.55rem;
  }
  .badge-glyph { color: var(--brand); }
  .page-body { padding: 1rem 1.2rem 1.2rem; color: var(--fg-soft); }
  .p-h {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
  }
  .p-line { font-size: var(--text-sm); line-height: var(--leading-normal); margin: 0.45rem 0; }
  .p-line code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--fg);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.05rem 0.3rem;
  }
  .cite {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 12%, transparent);
    border-radius: var(--radius-xs);
    padding: 0.05rem 0.3rem;
    margin-left: 0.25rem;
    vertical-align: super;
    line-height: 1;
  }

  /* coverage — the star */
  .coverage {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .cov-score, .cov-gaps { background: var(--surface); padding: 1.4rem 1.4rem; }
  .cov-score { display: flex; flex-direction: column; align-items: flex-start; gap: 0.55rem; }
  .cov-ring {
    --pct: 0;
    width: 92px; height: 92px;
    border-radius: var(--radius-full);
    display: grid;
    place-items: center;
    background:
      radial-gradient(closest-side, var(--surface) 78%, transparent 79% 100%),
      conic-gradient(var(--brand) calc(var(--pct) * 1%), var(--border-strong) 0);
  }
  .cov-num {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .cov-pct { font-size: var(--text-base); color: var(--fg-faint); margin-left: 1px; }
  .cov-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-faint);
  }
  .cov-sub { font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); max-width: 34ch; }
  .cov-sub code { font-family: var(--font-mono); font-size: 0.9em; color: var(--brand); }

  .cov-gaps { display: flex; flex-direction: column; gap: 0.7rem; }
  .gaps-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-faint);
  }
  .gaps-list { display: flex; flex-direction: column; gap: 0.45rem; }
  .gap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    list-style: none;
  }
  .gap-kind {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 40%, transparent);
    border-radius: var(--radius-xs);
    padding: 0.1rem 0.4rem;
    flex: none;
    min-width: 3.6rem;
    text-align: center;
  }
  .gap-name { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--fg); }
  .gap-loc {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-faint);
    margin-left: auto;
  }
  .gaps-note { font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }

  /* connect steps */
  .steps {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .step {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    list-style: none;
  }
  .step-n {
    flex: none;
    width: 26px; height: 26px;
    display: grid; place-items: center;
    border-radius: var(--radius-full);
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
    color: var(--brand);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
  }
  .step-body { min-width: 0; }
  .step-t {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .step-d { margin-top: 0.25rem; font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }
  .step-code {
    display: inline-block;
    margin-top: 0.55rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.2rem 0.5rem;
  }

  /* supporting notes */
  .notes {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .note {
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .note-t {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.3rem;
  }
  .note-d { font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }
  .note-d code { font-family: var(--font-mono); font-size: 0.9em; color: var(--brand); }

  .honesty {
    margin-top: 1.5rem;
    max-width: var(--measure);
    font-size: var(--text-sm);
    color: var(--fg-faint);
    line-height: var(--leading-normal);
  }
  .honesty strong { color: var(--fg-soft); font-weight: 600; }

  .more {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: var(--text-sm);
    color: var(--brand);
  }
  .more:hover { color: var(--brand-strong); text-decoration: underline; }

  @media (min-width: 760px) {
    .steps { grid-template-columns: repeat(3, 1fr); }
    .step { flex-direction: column; gap: 0.6rem; }
    .notes { grid-template-columns: 1fr 1fr; }
    .coverage { grid-template-columns: 0.8fr 1.2fr; }
  }

  @media (min-width: 900px) {
    .stage { grid-template-columns: 0.85fr auto 1.15fr; align-items: center; }
    .flow-arrow { transform: none; }
    .title { font-size: 2.875rem; }
  }

  /* the coverage ring fills from 0 → its score when scrolled in (compositor-safe
     property animation; SSR/no-JS shows the resolved ring). */
  @media (prefers-reduced-motion: no-preference) {
    .cov-ring { transition: none; }
    .coverage.cov-armed .cov-ring {
      animation: covfill 1100ms var(--ease-out) forwards;
    }
  }
  @keyframes covfill {
    from { background:
      radial-gradient(closest-side, var(--surface) 78%, transparent 79% 100%),
      conic-gradient(var(--brand) 0%, var(--border-strong) 0); }
  }
</style>

<script>
  // Fill the coverage ring once, when it scrolls into view. Reduced-motion / no-JS
  // simply renders the resolved 92% ring (the static frame is the truth).
  const cov = document.querySelector<HTMLElement>('#atlas .coverage');
  if (cov && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { cov.classList.add('cov-armed'); io.disconnect(); }
      }
    }, { threshold: 0.5 });
    io.observe(cov);
  }
</script>
