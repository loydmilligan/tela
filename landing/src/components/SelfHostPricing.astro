---
// SelfHostPricing — the editions detail, shown ONLY on the dedicated /pricing page
// (the on-page Pricing section carries just the cloud ladder). Implements the model in
// docs/editions-and-pricing.md: the two-axis story (where it runs decides the AI; which
// edition decides the company-layer), the self-host edition cards (Community / Enterprise
// / Commercial license), the cloud-vs-self-host matrix, and the core-vs-Enterprise line.
// Honest: self-host is BYO AI on EVERY edition; Community is the whole product, free.
const CONTACT_EMAIL = 'tela@telawiki.com';
const GITHUB_URL = 'https://github.com/zcag/tela';
const mailto = (subject) => `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}`;

// Self-host editions — TWO tiers only (the GitLab/open-core shape): the free
// Community core, and the paid Enterprise layer unlocked by a license key. The
// Commercial license (AGPL relief) is a real revenue lever but a lawyer's SKU,
// not a product tier — it lives in a strip below, not as a co-equal card.
const editions = [
  {
    name: 'Community',
    price: 'Free',
    period: 'AGPL-3.0, forever',
    blurb: 'The whole product, on your infrastructure.',
    specs: [
      'Full wiki, Atlas, search, agents, sheets, decks & sync',
      'Unlimited users, spaces & pages',
      'Bring your own AI — any OpenAI-compatible LLM + embedder',
      'Organizations & per-space roles',
      'Self-supported, community help',
    ],
    cta: 'Get the code',
    href: GITHUB_URL,
    action: 'github',
    featured: false,
  },
  {
    name: 'Enterprise',
    price: '$8',
    period: 'per user / mo, billed annually',
    blurb: 'The identity, governance and support a company needs — the price of a Team seat, on your own servers, unlocked by a license key.',
    specs: [
      'Everything in Community',
      'SSO / SAML / OIDC, SCIM provisioning',
      'Audit log, advanced RBAC, retention',
      'Premium Atlas connectors (Slack, Drive, GitHub…)',
      'Priority support + SLA',
    ],
    cta: 'Get a license',
    href: 'https://telawiki.com/settings?tab=licenses',
    action: 'app',
    featured: true,
  },
];

// The reconciler: ONE product, two tiers (rows), two ways to run it (cols). This
// is the table that kills the confusion — it shows Enterprise is the same feature
// layer whether we host it or you do, and that everything below it is free to
// self-host. Cloud costs more because it bundles managed AI + ops.
const matrix = {
  cols: ['tela Cloud — we host it · AI included', 'Self-host — you host it · BYO AI'],
  rows: [
    {
      label: 'Core',
      sub: 'the whole wiki + Atlas + AI',
      cloud: 'Free · Personal · Team',
      self: 'Community — free',
    },
    {
      label: 'Enterprise',
      sub: 'SSO · SCIM · audit · governance',
      cloud: 'from $15 / seat',
      self: '$8 / seat · license key',
    },
  ],
};

// Core vs Enterprise — what's free vs key-gated. ✓ / — rendered as marks.
const featureRows = [
  { f: 'Wiki, editor, history, page properties', core: true, ent: true },
  { f: 'Live collaboration, sheets, decks, WebDAV sync, MCP', core: true, ent: true },
  { f: 'Atlas, ask-your-docs, semantic search', core: true, ent: true },
  { f: 'Public spaces, custom domains', core: true, ent: true },
  { f: 'Organizations & per-space roles', core: true, ent: true },
  { f: 'SSO / SAML / OIDC', core: false, ent: true },
  { f: 'SCIM provisioning', core: false, ent: true },
  { f: 'Audit log', core: false, ent: true },
  { f: 'Advanced RBAC / custom roles / retention', core: false, ent: true },
  { f: 'Premium Atlas connectors (Slack, Drive, GitHub, Confluence)', core: false, ent: true },
  { f: 'HA / clustering, white-label', core: false, ent: true },
  { f: 'Priority support + SLA', core: false, ent: true },
];

const faqs = [
  {
    q: 'Do I need to pay for AI on self-host?',
    a: 'No — self-host is bring-your-own-AI on every edition, Community and Enterprise. Point tela at any OpenAI-compatible LLM and an Ollama-compatible embedder; the inference is yours. Managed, included AI is what the cloud plans are for.',
  },
  {
    q: 'What’s the difference between Cloud Enterprise and self-host Enterprise?',
    a: 'Same feature layer — SSO, SCIM, audit, advanced roles, governance, support. On cloud it’s bundled into your subscription and we run it (with managed AI). On self-host it’s a license key on your own infrastructure, and you bring your own AI.',
  },
  {
    q: 'It’s AGPL — can’t I just remove the Enterprise features myself?',
    a: 'Enterprise lives in a separate, proprietary module that ships inert without a license key — it isn’t part of the open core. The open core (everything in Community) is genuinely yours under the AGPL; Enterprise is the part you license.',
  },
  {
    q: 'Why would I pay if Community is the whole product?',
    a: 'You don’t pay for the software — you pay for managed AI + zero-ops (cloud), or for SSO, governance and a support contract (Enterprise), or for relief from AGPL copyleft (commercial license). The wiki and the AI capability are never the paywall.',
  },
];
---
<section id="self-host" class="section sh">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Self-host</p>
    <h2 class="h2">Run it yourself — free.</h2>
    <p class="lede">
      tela is open source, and the whole product is <strong>free to self-host</strong> —
      unlimited people, on your own infrastructure, bringing your own AI. You only ever pay
      for the <strong>Enterprise layer</strong>: the identity, governance and support a
      company needs, unlocked by a license key. <strong>Everything below Enterprise is free
      to self-host, forever.</strong>
    </p>
  </div>

  <div class="sh-cards reveal-up">
    {editions.map((e) => (
      <article class={`sh-card${e.featured ? ' sh-card--featured' : ''}`}>
        <header class="sh-head">
          <h3 class="sh-name">{e.name}</h3>
          {e.featured ? <span class="sh-tag">Most popular</span> : null}
        </header>
        <p class="sh-amount">
          <span class="sh-amt">{e.price}</span>
          <span class="sh-period">{e.period}</span>
        </p>
        <p class="sh-blurb">{e.blurb}</p>
        <ul class="sh-specs">
          {e.specs.map((s) => <li>{s}</li>)}
        </ul>
        <a
          href={e.href}
          class={e.featured ? 'sh-cta sh-cta--primary' : 'sh-cta'}
          target={e.action === 'github' ? '_blank' : undefined}
          rel={e.action === 'github' ? 'noopener' : undefined}
        >{e.cta}</a>
      </article>
    ))}
  </div>

  <p class="sh-commercial reveal-up">
    <span class="sh-commercial-label">Commercial license</span>
    Can’t ship AGPL? A flat annual commercial license gives you the full open core under
    commercial terms — no copyleft obligation, no feature gating — for legal or compliance
    constraints, even if you never touch Enterprise.
    <a href={mailto('tela commercial license')} class="sh-commercial-link">Contact us&nbsp;→</a>
  </p>

  <div class="sh-matrix reveal-up">
    <p class="sh-block-label">One product · two tiers · two ways to run it</p>
    <div class="sh-table-wrap">
      <table class="sh-table sh-table--map">
        <thead>
          <tr>
            <td class="sh-corner"></td>
            {matrix.cols.map((c) => <th scope="col">{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {matrix.rows.map((r) => (
            <tr>
              <th scope="row">{r.label} <span class="sh-row-sub">{r.sub}</span></th>
              <td>{r.cloud}</td>
              <td>{r.self}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="sh-note">Cloud is priced on managed AI + seats; self-host is free because you bring your own AI and infra. <strong>Enterprise is the same feature layer either way</strong> — you just pick who runs it.</p>
  </div>

  <div class="sh-features reveal-up">
    <p class="sh-block-label">What’s in the open core vs Enterprise</p>
    <div class="sh-table-wrap">
      <table class="sh-table sh-table--features">
        <thead>
          <tr>
            <th scope="col" class="sh-feat-col">Capability</th>
            <th scope="col">Core <span class="sh-col-sub">free</span></th>
            <th scope="col">Enterprise <span class="sh-col-sub">licensed</span></th>
          </tr>
        </thead>
        <tbody>
          {featureRows.map((row) => (
            <tr>
              <th scope="row">{row.f}</th>
              <td class={row.core ? 'is-yes' : 'is-no'}>
                <span class="sr-only">{row.core ? 'Included' : 'Not included'}</span>
                <span aria-hidden="true">{row.core ? '✓' : '—'}</span>
              </td>
              <td class={row.ent ? 'is-yes' : 'is-no'}>
                <span class="sr-only">{row.ent ? 'Included' : 'Not included'}</span>
                <span aria-hidden="true">{row.ent ? '✓' : '—'}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="sh-faq reveal-up">
    <p class="sh-block-label">Self-host questions</p>
    <div class="sh-faq-grid">
      {faqs.map((item) => (
        <div class="sh-faq-item">
          <h3 class="sh-faq-q">{item.q}</h3>
          <p class="sh-faq-a">{item.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sh { padding-top: 0; }

  .sh-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .sh-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .sh-card--featured {
    border-color: var(--pill-border);
    background: var(--brand-wash);
    box-shadow: var(--shadow-frame, none);
  }
  .sh-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .sh-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .sh-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-strong);
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }
  .sh-amount {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .sh-amt {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .sh-period {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--fg-faint);
  }
  .sh-blurb {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .sh-specs {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .sh-specs li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    padding-left: 1.1rem;
    position: relative;
  }
  .sh-specs li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--brand);
  }
  .sh-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .sh-cta:hover { border-color: var(--brand); background: var(--surface); }
  .sh-cta--primary {
    background: var(--cta-bg);
    border-color: transparent;
    color: var(--cta-fg);
  }
  .sh-cta--primary:hover { background: var(--cta-bg-hover); }

  .sh-block-label {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
  }

  /* Commercial license — a slim strip, not a co-equal card. */
  .sh-commercial {
    margin: 1rem 0 0;
    padding: 0.9rem 1.15rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface-sunk);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .sh-commercial-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin-right: 0.5rem;
  }
  .sh-commercial-link {
    color: var(--brand-strong);
    text-decoration: none;
    white-space: nowrap;
  }
  .sh-commercial-link:hover { text-decoration: underline; }

  .sh-matrix, .sh-features, .sh-faq { margin-top: 2.5rem; }

  /* Map table: two tiers × two run-modes. Row header carries a dim sub-label. */
  .sh-row-sub {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-faint);
    margin-top: 0.15rem;
  }
  .sh-table--map tbody th { width: 30%; }

  .sh-table-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .sh-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .sh-table th, .sh-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .sh-table tr:last-child th, .sh-table tr:last-child td { border-bottom: none; }
  .sh-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-soft);
    font-weight: 600;
    background: var(--surface-sunk);
  }
  .sh-table tbody th {
    color: var(--fg);
    font-weight: 500;
  }
  .sh-table tbody td { color: var(--fg-soft); }
  .sh-corner { background: var(--surface-sunk); border-bottom: 1px solid var(--border); }

  .sh-col-sub {
    display: block;
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: var(--fg-faint);
  }
  .sh-table--features tbody th { font-weight: 400; }
  .sh-table--features td { text-align: center; font-size: var(--text-base); width: 9rem; }
  .sh-feat-col { width: auto; }
  .sh-table .is-yes { color: var(--brand-strong); }
  .sh-table .is-no { color: var(--fg-faint); }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sh-note {
    margin: 0.85rem 0 0;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }

  .sh-faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 1.5rem;
  }
  .sh-faq-item {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .sh-faq-q {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
  }
  .sh-faq-a {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }

  @media (max-width: 900px) {
    .sh-cards { grid-template-columns: 1fr; }
    .sh-faq-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 620px) {
    .sh-table--features td { width: 4.5rem; }
    .sh-table th, .sh-table td { padding: 0.6rem 0.7rem; }
  }
</style>
