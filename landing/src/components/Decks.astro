---
// §6a — Presentations. A page flipped to a deck (props.deck=true) is a real
// presentation: present live in the browser (presenter mode, overview, draw),
// export to PDF/PPTX/PNG, and — the tela angle — agents author the whole thing
// over MCP. The showcase uses REAL rendered slides (public/decks/*.webp,
// rendered from a tela deck with the actual theme) so the quality is shown, not
// described. Engine names (Slidev/tahta) are credited at the bottom, never sold.
//
// To re-render (e.g. after a theme bump) — source is tooling/showcase-deck.md:
//   cd ../deck && PORT=3344 node server.mjs &        # deck sidecar (needs chromium)
//   curl -s -X POST "localhost:3344/render?variant=paper" \
//     --data-binary @../landing/tooling/showcase-deck.md   # -> {id, slides:[/d/<id>/<file>]}
//   # fetch each frame, then: magick <png> -resize 1280x -quality 82 public/decks/slide-0N.webp
const feats = [
  'Agents build whole presentations for you',
  'Present live — presenter mode, overview, draw',
  'Export to PDF, PPTX or PNG',
  'Plain markdown you own underneath',
];
// Real slides rendered from a tela deck (the cover leads the viewer).
const slides = [
  { src: '/decks/slide-001.webp', label: 'Stop pasting docs into chat' },
  { src: '/decks/slide-002.webp', label: 'Every task starts from zero' },
  { src: '/decks/slide-003.webp', label: 'What is tela?' },
  { src: '/decks/slide-004.webp', label: 'Retrieve, then write back' },
  { src: '/decks/slide-005.webp', label: 'A real wiki underneath' },
  { src: '/decks/slide-006.webp', label: 'Built for teams and agents' },
  { src: '/decks/slide-007.webp', label: 'Connect it — one URL' },
  { src: '/decks/slide-008.webp', label: "Your team's memory, shared" },
  { src: '/decks/slide-009.webp', label: 'Try tela' },
];
---
<section id="decks" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Presentations</p>
    <h2 class="h2">Presentations, built in.</h2>
    <p class="lede">
      tela makes <strong>real presentations</strong> — present them live in the browser, or
      export to PDF, PPTX or PNG. And because tela is agent-native, your agent can build the
      whole thing for you: ask Claude or ChatGPT to <em>"turn the launch notes into a 10-slide
      talk"</em> and it does.
    </p>
  </div>

  <div class="deck-wrap reveal-up">
    <!-- Real rendered slides: a framed viewer + clickable filmstrip -->
    <div class="deck-frame" data-deck>
      <div class="deck-bar">
        <span class="deck-dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="deck-chips">
          <span class="deck-chip deck-chip--go">Present</span>
          <span class="deck-chip">PDF</span>
          <span class="deck-chip">PPTX</span>
        </span>
      </div>

      <div class="deck-stage">
        <img
          class="deck-main"
          data-deck-main
          src={slides[0].src}
          width="1960"
          height="1104"
          alt={`A tela presentation slide: ${slides[0].label}. Made with the built-in deck theme.`}
          loading="lazy"
          decoding="async"
        />

        <ol class="deck-strip" aria-label="Slides in this presentation">
          {slides.map((s, i) => (
            <li>
              <button
                type="button"
                class={`deck-thumb${i === 0 ? ' is-current' : ''}`}
                data-deck-thumb
                data-src={s.src}
                data-label={s.label}
                aria-label={`Show slide ${i + 1}: ${s.label}`}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <img src={s.src} width="1960" height="1104" alt="" loading="lazy" decoding="async" />
              </button>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Capabilities -->
    <ul class="deck-feats">
      {feats.map((f) => (
        <li>
          <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          <span>{f}</span>
        </li>
      ))}
      <li class="deck-note">
        Slides are plain markdown underneath — portable like everything else in tela. Pick a
        theme and accent; agents preview and fix their own slides before handing them over.
      </li>
    </ul>
  </div>

  <p class="deck-credit reveal-up">
    Powered by
    <a href="https://sli.dev" target="_blank" rel="noopener">Slidev</a>
    and
    <a href="https://github.com/zcag/tahta" target="_blank" rel="noopener">tahta</a>.
  </p>
</section>

<script>
  // Filmstrip → swap the main slide. Pure progressive enhancement; without JS the
  // first slide simply shows and every thumbnail is still a real, visible slide.
  for (const deck of document.querySelectorAll('[data-deck]')) {
    const main = deck.querySelector('[data-deck-main]') as HTMLImageElement | null;
    const thumbs = deck.querySelectorAll<HTMLButtonElement>('[data-deck-thumb]');
    if (!main) continue;
    for (const thumb of thumbs) {
      thumb.addEventListener('click', () => {
        const src = thumb.dataset.src;
        const label = thumb.dataset.label ?? '';
        if (!src || main.src.endsWith(src)) return;
        main.src = src;
        main.alt = `A tela presentation slide: ${label}. Made with the built-in deck theme.`;
        for (const t of thumbs) {
          const on = t === thumb;
          t.classList.toggle('is-current', on);
          t.setAttribute('aria-pressed', on ? 'true' : 'false');
        }
      });
    }
  }
</script>

<style>
  .section-head .lede strong { color: var(--fg); font-weight: 600; }
  .section-head .lede em { color: var(--fg-soft); font-style: italic; }

  .deck-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  @media (min-width: 860px) {
    .deck-wrap { grid-template-columns: 1.5fr 1fr; gap: 2.5rem; }
  }

  /* ── slide viewer ─────────────────────────────────────────────────── */
  .deck-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-frame, none);
    overflow: hidden;
  }
  .deck-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    padding: 0.7rem 1.1rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-sunk);
  }
  .deck-dots { display: inline-flex; gap: 0.4rem; }
  .deck-dots i {
    width: 0.55rem; height: 0.55rem; border-radius: var(--radius-full);
    background: var(--border-strong);
  }
  .deck-chips { display: inline-flex; gap: 0.4rem; }
  .deck-chip {
    font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--fg-faint);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
  }
  .deck-chip--go {
    color: var(--brand-strong);
    background: var(--brand-wash);
    border-color: var(--pill-border);
  }

  .deck-stage { padding: 1rem; display: flex; flex-direction: column; gap: 0.85rem; }

  .deck-main {
    display: block;
    width: 100%; height: auto;
    aspect-ratio: 1960 / 1104;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--surface-sunk);
    transition: opacity var(--dur-fast, 140ms) var(--ease-out, ease);
  }

  /* filmstrip of real slide thumbnails */
  .deck-strip {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.55rem;
  }
  .deck-thumb {
    display: block; width: 100%; padding: 0;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-sunk);
    overflow: hidden;
    cursor: pointer;
    transition: border-color var(--dur-fast, 140ms) var(--ease-out, ease),
                transform var(--dur-fast, 140ms) var(--ease-out, ease);
  }
  .deck-thumb img {
    display: block;
    width: 100%; height: auto;
    aspect-ratio: 1960 / 1104;
    object-fit: cover;
  }
  .deck-thumb:hover { border-color: var(--border-strong); transform: translateY(-1px); }
  .deck-thumb:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .deck-thumb.is-current { border-color: var(--brand); box-shadow: var(--glow-brand, none); }

  @media (max-width: 560px) {
    .deck-strip { grid-template-columns: repeat(3, 1fr); gap: 0.4rem; }
  }

  /* ── capability list ──────────────────────────────────────────────── */
  .deck-feats { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.85rem; }
  .deck-feats li {
    display: flex; align-items: flex-start; gap: 0.55rem;
    font-size: var(--text-base); color: var(--fg-soft);
  }
  .deck-feats .tick { color: var(--brand); flex: none; margin-top: 0.2rem; }
  .deck-note {
    margin-top: 0.25rem; padding-top: 0.85rem;
    border-top: 1px solid var(--border);
    font-size: var(--text-sm); color: var(--fg-faint);
  }

  .deck-credit {
    margin-top: 1.75rem;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }
  .deck-credit a {
    color: var(--fg-soft);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--border-strong);
  }
  .deck-credit a:hover { color: var(--accent); text-decoration-color: var(--accent); }

  @media (prefers-reduced-motion: reduce) {
    .deck-main, .deck-thumb { transition: none; }
    .deck-thumb:hover { transform: none; }
  }
</style>
