---
// SiteHeader — glassy sticky masthead. Left-weighted wordmark + folded-paper mark,
// quiet nav, a GitHub-style credibility chip, theme toggle, and the primary CTA.
// Absolute (/#…) so the header works from any page, not just the homepage
// (e.g. the standalone /pricing route). Pricing links to its dedicated page.
const nav = [
  { label: 'Atlas', href: '/#atlas' },
  { label: 'Ask', href: '/#ask' },
  { label: 'Agents', href: '/#agents' },
  { label: 'Compare', href: '/#compare' },
  { label: 'Pricing', href: '/pricing' },
];
---

<header class="site-header">
  <div class="bar">
    <a href="/" class="brand" aria-label="tela — home">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 512 512" width="22" height="22" fill="none">
          <rect width="512" height="512" rx="112" fill="var(--cta-bg)" />
          <g transform="translate(-2.5,-38.5)">
            <path fill="var(--brand-fg)" d="M150 240 L196 188 Q205 178 218 178 H356 Q378 178 366 200 L332 240 Q325 250 312 250 H162 Q140 250 150 240 Z" />
            <path fill="var(--brand-fg)" d="M238 250 H296 Q300 250 300 268 V396 Q300 414 281 410 L245 402 Q226 398 226 380 V272 Q226 252 238 250 Z" />
            <path fill="#1e1b4b" fill-opacity="0.4" d="M250 250 H312 Q325 250 332 240 L304 270 Q297 278 297 290 V324 Z" />
          </g>
        </svg>
      </span>
      <span class="brand-word">tela</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((n) => <a href={n.href} class="nav-link">{n.label}</a>)}
    </nav>

    <div class="actions">
      <a
        class="ghost-chip"
        href="https://github.com/zcag/tela"
        target="_blank"
        rel="noopener"
        data-umami-event="outbound-link"
        data-umami-event-destination="github"
        data-umami-event-location="header"
      >
        <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <span class="chip-label">GitHub</span>
        <span class="chip-meta">self-host</span>
      </a>

      <button
        type="button"
        class="icon-btn theme-btn"
        aria-label="Toggle color theme"
        onclick="window.__telaToggleTheme()"
      >
        <svg class="ic-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"/>
        </svg>
        <svg class="ic-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/>
        </svg>
      </button>

      <a href="https://telawiki.com/login" class="ghost-btn" target="_blank" rel="noopener"
         data-umami-event="nav-login">Log in</a>
      <a href="https://telawiki.com/register" class="cta-btn" target="_blank" rel="noopener"
         data-umami-event="cta-click" data-umami-event-label="header-get-started">Get started</a>

      <button
        type="button"
        class="icon-btn menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="ic-open" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
        <svg class="ic-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile" hidden>
    {nav.map((n) => <a href={n.href} class="m-link">{n.label}</a>)}
    <div class="m-divider" role="separator"></div>
    <a class="m-link" href="https://github.com/zcag/tela" target="_blank" rel="noopener"
       data-umami-event="outbound-link" data-umami-event-destination="github" data-umami-event-location="mobile-menu">GitHub · self-host</a>
    <button type="button" class="m-link m-theme" onclick="window.__telaToggleTheme()">Toggle theme</button>
  </nav>

  <script is:inline>
    (function () {
      var btn = document.querySelector('.menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (!btn || !menu) return;
      function setOpen(open) {
        btn.setAttribute('aria-expanded', String(open));
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        menu.hidden = !open;
      }
      btn.addEventListener('click', function () {
        setOpen(menu.hidden);
      });
      // Close after picking a section link (theme toggle keeps the menu open).
      menu.querySelectorAll('a.m-link').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !menu.hidden) { setOpen(false); btn.focus(); }
      });
    })();
  </script>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px) saturate(1.2);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar {
    max-width: var(--col-max);
    margin-inline: auto;
    padding: 0.875rem var(--space-gutter);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.0625rem;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .brand-mark { display: inline-flex; }
  .brand-word { margin-top: 1px; }

  .nav {
    display: none;
    margin-left: 0.5rem;
    gap: 0.25rem;
  }
  .nav-link {
    color: var(--fg-soft);
    font-size: var(--text-sm);
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-sm);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .nav-link:hover { color: var(--fg); background: var(--surface); }

  .actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ghost-chip {
    display: none;
    align-items: center;
    gap: 0.4rem;
    height: 34px;
    padding: 0 0.7rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--fg-soft);
    font-size: var(--text-sm);
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .ghost-chip:hover { border-color: var(--brand); color: var(--fg); }
  .chip-meta {
    color: var(--fg-faint);
    border-left: 1px solid var(--border-strong);
    padding-left: 0.45rem;
    margin-left: 0.05rem;
    font-variant-numeric: tabular-nums;
  }

  .icon-btn {
    display: grid;
    place-items: center;
    width: 34px; height: 34px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--fg-soft);
    background: transparent;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .icon-btn:hover { border-color: var(--brand); color: var(--fg); }
  .ic-moon { display: none; }
  :global(:root:not([data-theme]) ) .ic-sun { display: block; }
  :global(:root[data-theme='dark']) .ic-sun { display: block; }
  :global(:root[data-theme='dark']) .ic-moon { display: none; }
  :global(:root[data-theme='light']) .ic-sun { display: none; }
  :global(:root[data-theme='light']) .ic-moon { display: block; }
  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .ic-sun { display: none; }
    :global(:root:not([data-theme])) .ic-moon { display: block; }
  }

  /* The bar theme toggle lives only on desktop; on mobile it moves into the menu. */
  .theme-btn { display: none; }
  /* Hamburger: mobile-only, swaps to a close glyph when the menu is open. */
  .menu-btn { display: grid; }
  .ic-close { display: none; }
  .menu-btn[aria-expanded='true'] .ic-open { display: none; }
  .menu-btn[aria-expanded='true'] .ic-close { display: block; }

  .ghost-btn {
    display: inline-flex;
    align-items: center;
    height: 34px;
    padding: 0 0.85rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    color: var(--fg);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .ghost-btn:hover { border-color: var(--brand); background: var(--surface); }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    height: 34px;
    padding: 0 0.95rem;
    border-radius: var(--radius-sm);
    background: var(--cta-bg);
    color: var(--cta-fg);
    font-size: var(--text-sm);
    font-weight: 500;
    box-shadow: var(--glow-brand);
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
  }
  .cta-btn:hover { background: var(--cta-bg-hover); }
  .cta-btn:active { transform: translateY(1px); }

  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.4rem var(--space-gutter) 1rem;
    border-top: 1px solid var(--nav-border);
  }
  .mobile-menu[hidden] { display: none; }
  .m-link {
    display: block;
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--fg-soft);
    font-family: inherit;
    font-size: var(--text-sm);
    padding: 0.7rem 0.55rem;
    border-radius: var(--radius-sm);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .m-link:hover { color: var(--fg); background: var(--surface); }
  .m-divider {
    height: 1px;
    background: var(--nav-border);
    margin: 0.4rem 0.55rem;
  }

  @media (min-width: 820px) {
    .nav { display: flex; }
    .theme-btn { display: grid; }
    .menu-btn { display: none; }
    .mobile-menu { display: none; }
    .ghost-chip { display: inline-flex; }
  }
</style>
