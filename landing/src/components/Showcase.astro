---
// §4 — Feature showcase. Scannable grid; 7 shipped + 2 honest "planned" cards.
// Planned cards are visually muted with a Planned tag and never styled as shipped.
const cards = [
  { t: 'Markdown all the way down', d: 'Every page is plain markdown — no block model, no proprietary format. Grep it, diff it, export it, walk away with it.', s: 'real', i: 'md' },
  { t: 'WYSIWYG that writes markdown', d: 'The Milkdown editor is fully WYSIWYG; the file underneath stays clean markdown. No mode-switching, no export step.', s: 'real', i: 'edit' },
  { t: 'Real-time multiplayer', d: 'Live collaborative editing over Yjs — concurrent cursors and edits, rebased onto the canonical markdown on save.', s: 'real', i: 'users' },
  { t: 'Instant full-text search', d: 'SQLite FTS5 over titles and bodies, snippet-highlighted, plus a command palette to jump anywhere. No Elasticsearch to run.', s: 'real', i: 'search' },
  { t: "Comments that don't drift", d: 'Comments anchor to the surrounding text (prefix · exact · suffix), so they stay put when the page is edited and reflowed.', s: 'real', i: 'comment' },
  { t: 'History and one-click revisions', d: 'Every body change auto-snapshots a revision. Read any past version, diff it, roll back in a click.', s: 'real', i: 'history' },
  { t: 'Share links, your way', d: 'Publish any page at a public link with optional password gating — same code, no extra service. Excalidraw diagrams render inline.', s: 'real', i: 'share' },
  { t: 'The link graph', d: 'Backlinks already exist on every page. The graph view that draws them — your wiki as a map you can navigate — is on the roadmap.', s: 'planned', i: 'graph' },
  { t: 'Mermaid, rendered', d: 'Mermaid blocks are preserved as code today and survive every round-trip. Rendering them inline is on the roadmap.', s: 'planned', i: 'diagram' },
];
const icons: Record<string, string> = {
  md: 'M4 7h16M4 12h16M4 17h10',
  edit: 'M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z',
  users: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M23 21v-2a4 4 0 0 0-3-3.87M16 3.13A4 4 0 0 1 16 11',
  search: 'M11 18a7 7 0 1 0 0-14 7 7 0 0 0 0 14zM21 21l-4.3-4.3',
  comment: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  history: 'M3 3v5h5M3.05 13A9 9 0 1 0 6 5.3L3 8M12 7v5l4 2',
  share: 'M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13',
  graph: 'M18 6a3 3 0 1 0 0-2 3 3 0 0 0 0 2zM6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM7.5 16.5l8-7M16.5 16.5l-8-7',
  diagram: 'M3 3h7v7H3zM14 14h7v7h-7zM14 3h7v4h-7zM3 14h7v4H3z',
};
---
<section id="features" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Features</p>
    <h2 class="h2">Here's what tela can do.</h2>
    <p class="lede">A real wiki, built on things you can grep, run, and export. Seven shipped today; two honest items still on the roadmap.</p>
  </div>

  <ul class="grid">
    {cards.map((c) => (
      <li class:list={['fcard', 'reveal-up', { planned: c.s === 'planned' }]}>
        <div class="fcard-top">
          <span class="ficon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={icons[c.i]} /></svg>
          </span>
          {c.s === 'planned' && <span class="ptag">Planned</span>}
        </div>
        <h3 class="fcard-title">{c.t}</h3>
        <p class="fcard-desc">{c.d}</p>
      </li>
    ))}
  </ul>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--border);
  }
  .fcard {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem;
    background: var(--surface);
    transition: background var(--dur) var(--ease-out);
  }
  .fcard:hover { background: var(--surface-hi); }
  .fcard-top { display: flex; align-items: center; justify-content: space-between; }
  .ficon {
    display: grid;
    place-items: center;
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    background: var(--brand-wash);
    color: var(--brand);
    border: 1px solid var(--pill-border);
  }
  .fcard-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .fcard-desc { color: var(--fg-soft); font-size: var(--text-sm); line-height: var(--leading-normal); }

  /* planned cards: visually muted + tagged, never identical to shipped */
  .fcard.planned { background: var(--surface-sunk); }
  .fcard.planned:hover { background: var(--surface-sunk); }
  .fcard.planned .ficon { background: transparent; color: var(--fg-faint); border-color: var(--border); }
  .fcard.planned .fcard-title { color: var(--fg-soft); }
  .fcard.planned .fcard-desc { color: var(--fg-faint); }
  .ptag {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.18rem 0.45rem;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-xs);
    color: var(--fg-faint);
  }

  @media (min-width: 640px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 980px) { .grid { grid-template-columns: 1fr 1fr 1fr; } }
</style>
