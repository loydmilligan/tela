---
// §3 — Retrieval: the shared engine, not a standalone feature. It indexes every page
// for meaning the moment it's written — Atlas drafts against it, ask-your-docs answers
// from it, agents call it. Keyword search misses; tela retrieves the right SECTION by
// meaning. Visual: a query → ranked chunk cards with heading path, snippet, score, and a
// hybrid (keyword + vector) badge. Then the for-humans / for-agents split, and an honest
// note about the embedder. Token-driven, no icons-as-decor.
const chunks = [
  {
    path: 'Runbooks ▸ Rollback',
    page: 'Incident response',
    space: 'Engineering',
    snip: 'revert the image tag, re-probe <mark>/api/version</mark>, then purge the edge cache',
    score: '0.89',
    via: 'vector',
  },
  {
    path: 'Deploy ▸ Production',
    page: 'Deploy runbook',
    space: 'Engineering',
    snip: 'if the canary drifts, <mark>roll back</mark> to the last green build before paging',
    score: '0.81',
    via: 'both',
  },
  {
    path: 'Postmortems ▸ 2026-05',
    page: 'api-latency outage',
    space: 'Engineering',
    snip: 'the <mark>undo</mark> took four minutes because the cache wasn’t purged first',
    score: '0.74',
    via: 'vector',
  },
];
---
<section id="search" class="rag-section">
  <div class="rag-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Retrieval · the engine underneath</p>
    <h2 class="h2">The engine underneath: search by meaning.</h2>
    <p class="lede">
      Retrieval is the shared engine the whole AI act runs on. The moment Atlas writes a page — or a
      human edits one — it's split into heading-aware chunks, embedded, and indexed for meaning. Atlas
      drafts against that index, ask-your-docs answers from it, and your agents call it. A search for
      “rollback steps” returns the runbook section that never uses the word: keyword and semantic
      results are ranked together, in the command palette for your team and through the connector for
      your agent.
    </p>
  </div>

  <!-- the engine, shown once: a query → ranked sections, then the two doors onto it -->
  <div class="rag-engine reveal-up">
    <div class="ragbox" aria-hidden="true">
      <div class="rag-bar">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="rag-q">rollback steps<span class="rag-caret"></span></span>
      </div>

      <ul class="rag-results">
        {chunks.map((c, i) => (
          <li class:list={['rchunk', { top: i === 0 }]}>
            <span class="rc-path">{c.path}</span>
            <p class="rc-snip" set:html={c.snip}></p>
            <span class="rc-page">{c.page}<span class="rc-space"> · {c.space}</span></span>
          </li>
        ))}
      </ul>

      <div class="rag-foot">
        <span>Top result has no “rollback” in it — matched on meaning</span>
      </div>
    </div>

    <!-- two doors onto the same index — light, not co-star cards -->
    <div class="rag-doors">
      <p class="door">
        <span class="rs-tag">For your team</span>
        <kbd>⌘K</kbd> over every space — sections ranked by relevance, matches highlighted.
      </p>
      <p class="door">
        <span class="rs-tag agent">For your agent</span>
        Claude and ChatGPT call the same index and get the matching section back, with a link to cite.
      </p>
    </div>
  </div>

  <p class="rag-honest reveal-up">
    Semantic search is on by default on the hosted instance. When self-hosting, keyword search
    works out of the box; semantic search needs an embedding model you point tela at.
  </p>
</section>

<style>
  /* Deliberately NARROWER than the col-max co-stars (Atlas, Agents): retrieval is
     the connective engine between them, so it reads quieter and tighter, not as a
     third full-width feature. */
  .rag-section {
    max-width: 60rem;
    margin-inline: auto;
    padding: var(--section-y) var(--space-gutter);
    scroll-margin-top: 5rem;
  }
  .rag-head { max-width: 46rem; margin-bottom: 2rem; }
  .rag-head .lede strong { color: var(--fg); font-weight: 600; }

  .rag-engine { display: flex; flex-direction: column; gap: 1rem; }

  /* ── retrieval visual ─────────────────────────────────────────────── */
  .ragbox {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .rag-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-sunk);
    color: var(--fg-faint);
  }
  .rag-q { color: var(--fg); font-size: var(--text-base); }
  .rag-caret { display: inline-block; width: 2px; height: 1em; margin-left: 1px; vertical-align: -2px; background: var(--brand); animation: ragblink 1.1s steps(2) infinite; }
  .rag-mode {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--brand);
    border: 1px solid var(--pill-border);
    background: var(--brand-wash);
    border-radius: var(--radius-xs);
    padding: 0.15rem 0.5rem;
  }

  .rag-results { display: flex; flex-direction: column; }
  .rchunk {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .rchunk:last-child { border-bottom: 0; }
  .rchunk.top { background: var(--brand-wash); }
  .rc-path {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--brand);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .rc-snip {
    margin-top: 0.35rem;
    font-size: var(--text-sm);
    color: var(--fg-soft);
    line-height: var(--leading-normal);
  }
  .rc-snip :global(mark) { background: transparent; color: var(--fg); font-weight: 600; }
  .rc-page { display: block; margin-top: 0.4rem; font-size: var(--text-xs); color: var(--fg-faint); }
  .rc-space { color: var(--fg-faint); }

  .rag-foot {
    display: flex;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--surface-sunk);
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }

  /* ── two doors onto the same index — lightweight, not co-star cards ── */
  .rag-doors {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem 1.5rem;
  }
  .door {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--fg-soft);
    line-height: var(--leading-normal);
    padding-left: 0.85rem;
    border-left: 2px solid var(--border-strong);
  }
  .rs-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-right: 0.5rem;
  }
  .rs-tag.agent { color: var(--brand); }
  .door kbd {
    font-family: var(--font-mono); font-size: 0.85em;
    padding: 1px 5px; border: 1px solid var(--border-strong);
    border-radius: var(--radius-xs); color: var(--fg-soft);
  }
  .rag-honest {
    margin-top: 1.25rem;
    max-width: var(--measure);
    font-size: var(--text-sm);
    color: var(--fg-faint);
    line-height: var(--leading-normal);
  }
  .rag-honest code { font-family: var(--font-mono); font-size: 0.9em; color: var(--fg-soft); }

  @keyframes ragblink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .rag-caret { animation: none; } }

  @media (min-width: 720px) {
    .rag-doors { grid-template-columns: 1fr 1fr; }
  }
</style>
