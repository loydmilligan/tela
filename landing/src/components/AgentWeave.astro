---
// AgentWeave — the carved-out signature moment (motion-throttle-exempt).
// Left: a real chat exchange the way a user sees it in Claude/ChatGPT — a question,
// a "searched/updated the wiki" indicator, an answer. Right: tela's editor, where the
// loom threads sweep and the page materializes as the assistant commits an edit.
// Reads in <5s as "the AI is using the wiki, not chatting about it." No JSON, no code:
// the user never sees a tool call. Reduced-motion / no-JS render the resolved frame.
import EditorMock from './EditorMock.astro';

// The chat turns, exactly as they'd appear in the chat app. `tool` turns are the small
// "used a connector" indicators; the one flagged `commit` triggers the page weave.
const turns = [
  { who: 'user', text: 'What are the rollback steps for an incident?' },
  { who: 'tool', text: 'Searched the wiki — Incident response' },
  { who: 'bot',  text: 'Revert the image tag, re-probe /api/version, then purge the edge cache. Source: Incident response → Rollback.' },
  { who: 'user', text: 'Add a note to purge the cache first.' },
  { who: 'tool', text: 'Updated Incident response', commit: true },
  { who: 'bot',  text: 'Done — added it under Rollback.' },
];

// real tool catalog (subset shown, grouped by scope) — names from internal/api/mcp_tools.go
const toolScopes = [
  { scope: 'read', tone: 'read', tools: ['research', 'search', 'read_chunk', 'related_pages', 'suggest_links', 'get_page', 'list_pages', 'list_backlinks', 'atlas_list_projects', 'atlas_run_status'] },
  { scope: 'write', tone: 'write', tools: ['create_page', 'update_page', 'add_comment', 'move_page'] },
  { scope: 'admin', tone: 'admin', tools: ['create_space', 'update_space', 'manage keys', 'atlas_run'] },
];

// how you connect the chat apps — no install, no local proxy
const connectSteps = [
  { n: '1', t: 'Add a connector', d: 'In Claude or ChatGPT, add tela as a connector.', code: 'tela.cagdas.io/api/mcp' },
  { n: '2', t: 'Sign in', d: 'One sign-in with your tela account. No token to paste.', code: 'OAuth 2.1' },
  { n: '3', t: 'Use it', d: 'The assistant searches and edits the wiki, within your permissions.', code: '39 tools' },
];
---

<section id="agents" class="agentweave" data-agentweave>
  <div class="head">
    <p class="eyebrow"><span class="eyebrow-dot"></span>The agent layer</p>
    <h2 class="title">Already in Claude and ChatGPT.</h2>
    <p class="lede">
      Your AI already lives in the chat apps you work in, so tela connects to them — instead of
      bolting a chat box onto a wiki you'd have to go open. Connect once and the assistant searches
      your docs, reads and writes pages, and adds comments, limited to what your account can access.
      Below: a question answered from the wiki, then a page edited — without leaving the chat.
    </p>
  </div>

  <div class="stage">
    <!-- LEFT: the chat, the way a user sees it -->
    <div class="chatpanel">
      <div class="cp-top">
        <span class="cp-tab"><span class="cp-glyph">✳</span> Claude</span>
        <span class="cp-conn">tela connected</span>
      </div>
      <div class="chat" data-chat aria-hidden="true">
        {turns.map((t) => (
          t.who === 'tool' ? (
            <div class="turn tool" data-turn data-commit={t.commit ? 'true' : 'false'}>
              <span class="tool-chip">
                {t.commit
                  ? <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
                  : <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>}
                {t.text}
              </span>
            </div>
          ) : (
            <div class:list={['turn', t.who]} data-turn>
              <span class:list={['bubble', t.who]}>{t.text}</span>
            </div>
          )
        ))}
      </div>
    </div>

    <!-- RIGHT: the wiki the agent is weaving -->
    <div class="loomwrap">
      <div class="sweep" data-sweep aria-hidden="true"></div>
      <EditorMock staged class="loom-editor" />
    </div>
  </div>

  <!-- the connect flow — the whole integration -->
  <div class="connect reveal-up">
    <ol class="connect-steps">
      {connectSteps.map((s) => (
        <li class="cstep">
          <span class="cs-n">{s.n}</span>
          <div class="cs-body">
            <h3 class="cs-t">{s.t}</h3>
            <p class="cs-d">{s.d}</p>
            <code class="cs-code">{s.code}</code>
          </div>
        </li>
      ))}
    </ol>
    <p class="connect-cap">Available in the <strong>Claude</strong> and <strong>ChatGPT</strong> connector directories. Nothing to install.</p>
    <p class="codeagents">Using Claude Code, Cursor, or your own client? Connect to the same address: <code>tela.cagdas.io/api/mcp</code>.</p>
  </div>

  <!-- the tool catalog, grouped by scope -->
  <div class="tools reveal-up">
    <div class="tools-head">
      <h3 class="tools-title">39 tools, grouped by access</h3>
      <p class="tools-sub">Give an agent a read-only key, or one that can write. A key can be pinned to a single space.</p>
    </div>
    <div class="tools-grid">
      {toolScopes.map((g) => (
        <div class="scope">
          <span class:list={['scope-tag', g.tone]}>{g.scope}</span>
          <ul class="scope-tools">
            {g.tools.map((t) => <li><code>{t}</code></li>)}
          </ul>
        </div>
      ))}
    </div>
    <p class="tools-why">
      The assistant reads from the wiki and writes back to it, so context carries from one session
      to the next instead of being pasted in each time. It can also surface related pages, suggest
      links while writing, and flag overlapping content — and even kick off an Atlas run and check
      its status — so the knowledge base stays connected and current as it grows.
    </p>
    <a class="tools-link" href="/mcp/">See the full tool catalog →</a>
  </div>
</section>

<style>
  .agentweave {
    max-width: var(--col-max);
    margin-inline: auto;
    padding: var(--section-y) var(--space-gutter);
    scroll-margin-top: 5rem;
  }

  .head { max-width: 46rem; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-kicker);
    color: var(--brand);
    margin-bottom: 1rem;
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--brand); box-shadow: var(--glow-brand); }
  .title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-snug);
    color: var(--fg);
  }
  .lede {
    margin-top: 1.1rem;
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: var(--measure);
  }
  .lede strong { color: var(--fg); font-weight: 600; }

  .stage {
    margin-top: 2.75rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* chat panel */
  .chatpanel {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    min-height: 232px;
  }
  .cp-top {
    display: flex;
    align-items: center;
    height: 36px;
    padding: 0 0.8rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-sunk);
  }
  .cp-tab {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
  }
  .cp-glyph { color: var(--brand); }
  .cp-conn {
    margin-left: auto;
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
  }
  .cp-conn::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: var(--radius-full);
    background: var(--live-dot);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 22%, transparent);
  }

  .chat {
    flex: 1;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .turn { display: flex; }
  .turn.user { justify-content: flex-end; }
  .turn.bot { justify-content: flex-start; }
  .bubble {
    max-width: 86%;
    padding: 0.6rem 0.8rem;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    border-radius: var(--radius-md);
  }
  .bubble.user {
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
    color: var(--fg);
    border-bottom-right-radius: var(--radius-xs);
  }
  .bubble.bot {
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    color: var(--fg-soft);
    border-bottom-left-radius: var(--radius-xs);
  }
  .turn.tool { justify-content: flex-start; }
  .tool-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    background: var(--surface-sunk);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }
  .tool-chip svg { color: var(--brand); flex: none; }

  /* sequential reveal (only while the signature is playing; SSR shows all) */
  .turn { transition: opacity var(--dur) var(--ease-out), transform var(--dur) var(--ease-out); }
  .chat.playing .turn { opacity: 0; transform: translateY(8px); }
  .chat.playing .turn.show { opacity: 1; transform: none; }

  /* loom (editor + sweep) */
  .loomwrap { position: relative; min-width: 0; }
  .loom-editor { position: relative; z-index: 1; }
  .sweep {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    border-radius: var(--radius-lg);
    opacity: 0;
    background:
      repeating-linear-gradient(
        to right,
        var(--weave-thread) 0,
        var(--weave-thread) 1px,
        transparent 1px,
        transparent var(--weave-cell)
      );
    -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    -webkit-mask-size: 460% 100%;
    mask-size: 460% 100%;
    -webkit-mask-position: 0% 0;
    mask-position: 0% 0;
  }
  .loomwrap.is-weaving .sweep {
    opacity: 0.9;
    animation: sweep var(--dur-weave) var(--ease-in-out) forwards;
  }
  @keyframes sweep {
    0%   { -webkit-mask-position: 0% 0;   mask-position: 0% 0;   opacity: 0; }
    8%   { opacity: 0.9; }
    92%  { opacity: 0.9; }
    100% { -webkit-mask-position: 100% 0; mask-position: 100% 0; opacity: 0; }
  }

  /* connect flow — three steps, the whole integration */
  .connect { margin-top: 1.75rem; }
  .connect-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .cstep {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .cs-n {
    flex: none;
    width: 26px; height: 26px;
    display: grid; place-items: center;
    border-radius: var(--radius-full);
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
    color: var(--brand);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
  }
  .cs-body { min-width: 0; }
  .cs-t {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .cs-d { margin-top: 0.25rem; font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }
  .cs-code {
    display: inline-block;
    margin-top: 0.55rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.2rem 0.5rem;
    max-width: 100%;
    overflow-x: auto;
    white-space: nowrap;
  }
  .connect-cap {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--fg-faint);
    line-height: var(--leading-normal);
  }
  .connect-cap strong { color: var(--fg-soft); font-weight: 600; }
  .codeagents {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--fg-faint);
    line-height: var(--leading-normal);
  }
  .codeagents code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--fg-soft);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.1rem 0.4rem;
  }

  /* tool catalog */
  .tools { margin-top: 2.5rem; }
  .tools-head { max-width: 44rem; }
  .tools-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .tools-sub { margin-top: 0.5rem; color: var(--fg-soft); font-size: var(--text-base); }
  .tools-sub code, .tools-why code { font-family: var(--font-mono); font-size: 0.92em; color: var(--brand); }
  .tools-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .scope {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .scope-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border-strong);
    color: var(--fg-soft);
    flex: none;
    min-width: 4.5rem;
    text-align: center;
  }
  .scope-tag.read { color: var(--accent); border-color: color-mix(in oklab, var(--accent) 40%, transparent); }
  .scope-tag.write { color: var(--brand); border-color: var(--pill-border); background: var(--brand-wash); }
  .scope-tag.admin { color: var(--fg-faint); }
  .scope-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .scope-tools li { list-style: none; }
  .scope-tools code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.22rem 0.5rem;
    border-radius: var(--radius-xs);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    color: var(--fg-soft);
  }
  .tools-why {
    margin-top: 1.5rem;
    max-width: var(--measure);
    color: var(--fg-soft);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }
  .tools-link {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: var(--text-sm);
    color: var(--brand);
  }
  .tools-link:hover { color: var(--brand-strong); text-decoration: underline; }

  @media (min-width: 720px) {
    .scope { flex-wrap: nowrap; }
    .connect-steps { grid-template-columns: repeat(3, 1fr); }
    .cstep { flex-direction: column; gap: 0.6rem; }
  }

  @media (min-width: 900px) {
    .stage { grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr); gap: 1.5rem; }
    .title { font-size: 2.875rem; }
  }
</style>

<script>
  // The signature moment. Self-contained, guarded by reduced-motion + an
  // IntersectionObserver so it only plays when scrolled into view, once.
  // SSR renders the full chat + finished page; JS replays it on scroll.
  const section = document.querySelector<HTMLElement>('[data-agentweave]');
  if (section) {
    const chat = section.querySelector<HTMLElement>('[data-chat]');
    const loom = section.querySelector<HTMLElement>('.loomwrap');
    const turns = Array.from(section.querySelectorAll<HTMLElement>('[data-turn]'));
    const lines = Array.from(section.querySelectorAll<HTMLElement>('[data-line]'));
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    async function play() {
      if (!chat) return;
      // arm: hide staged editor lines (EditorMock CSS keys on .is-animating) + chat turns
      section.classList.add('is-animating');
      chat.classList.add('playing');
      for (const t of turns) {
        await wait(t.classList.contains('tool') ? 520 : 760);
        t.classList.add('show');
        if (t.dataset.commit === 'true') {
          loom?.classList.add('is-weaving');
          const step = 1600 / Math.max(lines.length, 1);
          lines.forEach((l, i) => setTimeout(() => l.classList.add('lit'), i * step));
          await wait(1500);
        }
      }
    }

    if (!reduce) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { io.disconnect(); play(); }
        }
      }, { threshold: 0.4 });
      io.observe(section);
    }
  }
</script>
