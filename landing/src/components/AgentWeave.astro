---
// AgentWeave — the carved-out signature moment (motion-throttle-exempt).
// Left: a real MCP tool-call (update_page) types out. Right: tela's editor, where
// the loom threads sweep left→right and the page materializes line-by-line as the
// call commits. Reads in <5s as "the agent is editing the wiki, not chatting about
// it." Reduced-motion renders the resolved static frame (no typing, no sweep).
import EditorMock from './EditorMock.astro';

// The tool-call script the panel types out. Tokens carry highlight classes.
const callLines = [
  { t: 'comment', s: '// claude · model context protocol' },
  { t: 'call',    s: 'tela.update_page({' },
  { t: 'arg',     s: '  space: "engineering",' },
  { t: 'arg',     s: '  page:  "incident-response",' },
  { t: 'arg',     s: '  body:  "# Incident response\\n\\nWhen a service…"' },
  { t: 'call',    s: '})' },
];
const resultLines = [
  '← { page: { id: "pg_8fa2c1",',
  '    title: "Incident response",',
  '    updated_at: "just now" } }',
];

// .mcp.json sample — built as an HTML string and injected with set:html so
// Astro doesn't parse the literal { } as template expressions.
const k = (s: string) => `<span class="k">"${s}"</span>`;
const v = (s: string) => `<span class="s">"${s}"</span>`;
// Static, server-rendered tool-call frame (the resolved end state). JS resets
// this to blank and types it out when the section scrolls into view; with no JS
// or reduced-motion it simply stays — never a blank panel.
const escH = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const hlH = (s: string) => escH(s).replace(/"([^"]*)"/g, (_m, g1) => `<span class="qs">"${g1}"</span>`);
const staticCall = callLines.map((l) => `<span class="l-${l.t}">${hlH(l.s)}</span>`).join('\n')
  + '\n\n'
  + resultLines.map((s) => `<span class="l-result">${escH(s)}</span>`).join('\n');

// real tool catalog (subset shown, grouped by scope) — names from mcp/README.md
const toolScopes = [
  { scope: 'read', tone: 'read', tools: ['search', 'get_page', 'list_pages', 'list_backlinks'] },
  { scope: 'write', tone: 'write', tools: ['create_page', 'update_page', 'add_comment', 'import_markdown'] },
  { scope: 'admin', tone: 'admin', tools: ['create_space', 'update_space', 'manage_keys'] },
];

const mcpJson = [
  `{`,
  `  ${k('mcpServers')}: {`,
  `    ${k('tela')}: {`,
  `      ${k('command')}: ${v('npx')},`,
  `      ${k('args')}: [${v('-y')}, ${v('tela-mcp')}],`,
  `      ${k('env')}: { ${k('TELA_URL')}: ${v('https://tela.cagdas.io')},`,
  `              ${k('TELA_TOKEN')}: ${v('tela_pat_…')} }`,
  `    }`,
  `  }`,
  `}`,
].map((l) => `<span class="ln">${l}</span>`).join('\n');
---

<section id="agents" class="agentweave" data-agentweave>
  <div class="head">
    <p class="eyebrow"><span class="eyebrow-dot"></span>The agent layer</p>
    <h2 class="title">Point an agent at your wiki.<br />Watch it write the page.</h2>
    <p class="lede">
      A first-class <strong>MCP server</strong> — not a chat box bolted on. Agents authenticate
      with a token and call the same API your team uses. Here's one call, start to finish.
    </p>
  </div>

  <div class="stage">
    <!-- LEFT: the MCP tool-call panel -->
    <div class="callpanel" aria-hidden="true">
      <div class="cp-top">
        <span class="cp-tab"><span class="cp-glyph">⌘</span> MCP · stdio</span>
        <span class="cp-status" data-cp-status data-state="done">done</span>
      </div>
      <pre class="cp-code"><code data-cp-code set:html={staticCall}></code></pre>
    </div>

    <!-- RIGHT: the wiki the agent is weaving -->
    <div class="loomwrap">
      <div class="sweep" data-sweep aria-hidden="true"></div>
      <EditorMock staged class="loom-editor" />
    </div>
  </div>

  <!-- the real config, plainly -->
  <div class="mcpconfig">
    <div class="mc-head">
      <span class="mc-label">.mcp.json</span>
      <span class="mc-note">point any MCP client at tela — Claude, Cursor, your own agent</span>
    </div>
    <pre class="mc-code" tabindex="0" aria-label=".mcp.json configuration"><code set:html={mcpJson}></code></pre>
    <p class="mc-cap">Drop this in your <code>.mcp.json</code>. That's the whole integration.</p>
  </div>

  <!-- the tool catalog, grouped by scope -->
  <div class="tools reveal-up">
    <div class="tools-head">
      <h3 class="tools-title">17 tools over the same REST API the UI uses</h3>
      <p class="tools-sub">Scoped <code>tela_pat_…</code> keys — read, write, or admin, pinnable to a single space.</p>
    </div>
    <div class="tools-grid">
      {toolScopes.map((g) => (
        <div class="scope">
          <span class:list={['scope-tag', g.tone]}>{g.scope}</span>
          <ul class="scope-tools">
            {g.tools.map((t) => <li><code>{t}</code></li>)}
          </ul>
        </div>
      ))}
    </div>
    <p class="tools-why">
      No starting from zero every session. The agent reads the team's docs and writes back what
      it learns — the next session picks up where it left off.
    </p>
    <a class="tools-link" href="https://github.com/zcag/tela/blob/main/mcp/README.md" target="_blank" rel="noopener">See the full tool catalog →</a>
  </div>

  <script type="application/json" data-aw-data set:html={JSON.stringify({ callLines, resultLines })}></script>
</section>

<style>
  .agentweave {
    max-width: var(--col-max);
    margin-inline: auto;
    padding: var(--section-y) var(--space-gutter);
    scroll-margin-top: 5rem;
  }

  .head { max-width: 46rem; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-kicker);
    color: var(--brand);
    margin-bottom: 1rem;
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--brand); box-shadow: var(--glow-brand); }
  .title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-snug);
    color: var(--fg);
  }
  .lede {
    margin-top: 1.1rem;
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: var(--measure);
  }
  .lede strong { color: var(--fg); font-weight: 600; }

  .stage {
    margin-top: 2.75rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* call panel */
  .callpanel {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--surface-sunk);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    min-height: 232px;
  }
  .cp-top {
    display: flex;
    align-items: center;
    height: 36px;
    padding: 0 0.8rem;
    border-bottom: 1px solid var(--border);
    background: color-mix(in oklab, var(--surface-sunk) 80%, var(--bg));
  }
  .cp-tab {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
  }
  .cp-glyph { color: var(--brand); }
  .cp-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .cp-status::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: var(--radius-full);
    background: currentColor;
  }
  .cp-status[data-state='done'] { color: var(--brand-strong); }
  .cp-code {
    flex: 1;
    margin: 0;
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--fg);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .cp-code :global(.l-comment) { color: var(--fg-faint); }
  .cp-code :global(.l-call) { color: var(--fg); }
  .cp-code :global(.l-arg) { color: var(--fg-soft); }
  .cp-code :global(.l-arg .qs) { color: var(--code-string); }
  .cp-code :global(.l-result) { color: var(--accent); }
  .cp-code :global(.tcaret) {
    display: inline-block;
    width: 7px; height: 1.05em;
    margin-left: 1px;
    vertical-align: text-bottom;
    background: var(--brand);
    animation: tblink 1.05s steps(2, start) infinite;
  }
  @keyframes tblink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  /* loom (editor + sweep) */
  .loomwrap { position: relative; }
  .loom-editor { position: relative; z-index: 1; }
  .sweep {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    border-radius: var(--radius-lg);
    opacity: 0;
    background:
      repeating-linear-gradient(
        to right,
        var(--weave-thread) 0,
        var(--weave-thread) 1px,
        transparent 1px,
        transparent var(--weave-cell)
      );
    -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    -webkit-mask-size: 460% 100%;
    mask-size: 460% 100%;
    -webkit-mask-position: 0% 0;
    mask-position: 0% 0;
  }
  .loomwrap.is-weaving .sweep {
    opacity: 0.9;
    animation: sweep var(--dur-weave) var(--ease-in-out) forwards;
  }
  @keyframes sweep {
    0%   { -webkit-mask-position: 0% 0;   mask-position: 0% 0;   opacity: 0; }
    8%   { opacity: 0.9; }
    92%  { opacity: 0.9; }
    100% { -webkit-mask-position: 100% 0; mask-position: 100% 0; opacity: 0; }
  }

  /* the real config card */
  .mcpconfig {
    margin-top: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    overflow: hidden;
  }
  .mc-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .mc-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--brand); }
  .mc-note { font-size: var(--text-xs); color: var(--fg-faint); }
  .mc-code {
    margin: 0;
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.75;
    color: var(--fg-soft);
    overflow-x: auto;
  }
  .mc-code .k { color: var(--code-token); }
  .mc-code .s { color: var(--code-string); }
  .mc-code .ln { display: block; }
  .mc-cap {
    padding: 0 1rem 0.9rem;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }
  .mc-cap code { font-family: var(--font-mono); color: var(--fg-soft); }

  /* tool catalog */
  .tools { margin-top: 2.5rem; }
  .tools-head { max-width: 44rem; }
  .tools-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .tools-sub { margin-top: 0.5rem; color: var(--fg-soft); font-size: var(--text-base); }
  .tools-sub code, .tools-why code { font-family: var(--font-mono); font-size: 0.92em; color: var(--brand); }
  .tools-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .scope {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .scope-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border-strong);
    color: var(--fg-soft);
    flex: none;
    min-width: 4.5rem;
    text-align: center;
  }
  .scope-tag.read { color: var(--accent); border-color: color-mix(in oklab, var(--accent) 40%, transparent); }
  .scope-tag.write { color: var(--brand); border-color: var(--pill-border); background: var(--brand-wash); }
  .scope-tag.admin { color: var(--fg-faint); }
  .scope-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .scope-tools li { list-style: none; }
  .scope-tools code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.22rem 0.5rem;
    border-radius: var(--radius-xs);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    color: var(--fg-soft);
  }
  .tools-why {
    margin-top: 1.5rem;
    max-width: var(--measure);
    color: var(--fg-soft);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }
  .tools-link {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: var(--text-sm);
    color: var(--brand);
  }
  .tools-link:hover { color: var(--brand-strong); text-decoration: underline; }

  @media (min-width: 720px) {
    .tools-grid { grid-template-columns: 1fr; }
    .scope { flex-wrap: nowrap; }
  }

  @media (min-width: 900px) {
    .stage { grid-template-columns: 0.92fr 1.08fr; gap: 1.5rem; }
    .title { font-size: 2.875rem; }
  }
</style>

<script>
  // The signature moment. Self-contained, guarded by reduced-motion + an
  // IntersectionObserver so it only plays when scrolled into view, once.
  const section = document.querySelector<HTMLElement>('[data-agentweave]');
  if (section) {
    const dataEl = section.querySelector<HTMLElement>('[data-aw-data]');
    const codeEl = section.querySelector<HTMLElement>('[data-cp-code]');
    const statusEl = section.querySelector<HTMLElement>('[data-cp-status]');
    const loom = section.querySelector<HTMLElement>('.loomwrap');
    const editor = section.querySelector<HTMLElement>('[data-editor]');
    const lines = Array.from(section.querySelectorAll<HTMLElement>('[data-line]'));
    const data = dataEl ? JSON.parse(dataEl.textContent || '{}') : { callLines: [], resultLines: [] };

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    const esc = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    // wrap "double quoted" substrings in a string-highlight span
    const hl = (s: string) => esc(s).replace(/&quot;|"([^"]*)"/g, (m, g1) =>
      g1 !== undefined ? `<span class="qs">"${g1}"</span>` : m);

    async function typeLine(html: string, cls: string, perChar: number) {
      if (!codeEl) return;
      const span = document.createElement('span');
      span.className = cls;
      codeEl.appendChild(span);
      codeEl.appendChild(document.createTextNode('\n'));
      // type by character on the raw text, then swap in highlighted html
      const tmp = document.createElement('div');
      tmp.innerHTML = html;
      const text = tmp.textContent || '';
      const caret = document.createElement('span');
      caret.className = 'tcaret';
      for (let i = 0; i < text.length; i++) {
        span.textContent = text.slice(0, i + 1);
        span.appendChild(caret);
        await wait(perChar);
      }
      span.innerHTML = html; // final highlighted form (drops caret)
    }

    async function play() {
      if (!codeEl) return;
      // arm: hide the staged editor lines + reset the panel to blank, then type.
      section.classList.add('is-animating');
      statusEl?.setAttribute('data-state', 'running');
      if (statusEl) statusEl.textContent = 'running';
      codeEl.innerHTML = '';
      for (const l of data.callLines) {
        await typeLine(hl(l.s), `l-${l.t}`, l.t === 'comment' ? 8 : 16);
        await wait(90);
      }
      await wait(360);
      // commit → weave
      loom?.classList.add('is-weaving');
      const step = 1700 / Math.max(lines.length, 1);
      lines.forEach((l, i) => setTimeout(() => l.classList.add('lit'), 360 + i * step));
      await wait(1700);
      statusEl?.setAttribute('data-state', 'done');
      if (statusEl) statusEl.textContent = 'done';
      codeEl.appendChild(document.createTextNode('\n'));
      for (const s of data.resultLines) {
        const r = document.createElement('span');
        r.className = 'l-result';
        r.textContent = s;
        codeEl.appendChild(r);
        codeEl.appendChild(document.createTextNode('\n'));
        await wait(120);
      }
    }

    // Reduced-motion (or no JS) keeps the server-rendered static frame as-is.
    if (!reduce) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            io.disconnect();
            play();
          }
        }
      }, { threshold: 0.4 });
      io.observe(section);
    }
  }
</script>
