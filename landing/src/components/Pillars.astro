---
// §6 — Pillars strip. The three load-bearing promises, stated plainly.
const pillars = [
  { t: 'Markdown is canonical. Forever.', d: 'Every page is plain markdown text — no block model, no proprietary format. The Milkdown editor is WYSIWYG; the file underneath is markdown. Bulk-import a directory, export anytime. Leaving tela means copying files.', tag: 'own it' },
  { t: 'One binary. SQLite. Your server.', d: 'Go compiles to a single binary; storage and full-text search are SQLite + FTS5 — no Postgres, no Elasticsearch, nothing extra to operate. docker compose up, one host port, your data on your disk.', tag: 'run it' },
  { t: 'Real-time multiplayer.', d: 'Live collaborative editing over Yjs: concurrent cursors and edits, rebased onto the canonical markdown on save. Comments anchor to the surrounding text, so they don’t drift when the doc is reflowed.', tag: 'live' },
];
---
<section class="section section--tight">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Foundations</p>
    <h2 class="h2">A wiki built on things you can grep, run, and export.</h2>
  </div>
  <div class="pgrid">
    {pillars.map((p, i) => (
      <div class="pcard reveal-up">
        <span class="pnum">0{i + 1}</span>
        <span class="ptag">{p.tag}</span>
        <h3 class="ptitle">{p.t}</h3>
        <p class="pdesc">{p.d}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .pgrid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .pcard {
    position: relative;
    padding: 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    overflow: hidden;
  }
  .pnum {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--brand);
  }
  .ptag {
    position: absolute;
    top: 1.6rem; right: 1.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ptitle {
    margin-top: 0.9rem;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .pdesc { margin-top: 0.7rem; color: var(--fg-soft); font-size: var(--text-sm); line-height: var(--leading-normal); }
  @media (min-width: 880px) { .pgrid { grid-template-columns: 1fr 1fr 1fr; } }
</style>
