---
// §11 — FAQ. Question-led, answer-first prose. Native <details> (keyboard-accessible,
// no JS). No FAQPage schema (rich results retired 2026).
const qs = [
  { q: 'Does it work inside Claude and ChatGPT?', a: 'Yes. tela runs a remote MCP server with OAuth sign-in; add it as a connector in Claude or ChatGPT (it’s submitted to both directories) and your agent searches, reads, and writes your wiki — scoped to your account. Code agents like Claude Code or Cursor point at the same URL with a token.' },
  { q: 'How is search different from a normal wiki?', a: 'tela ranks results by meaning as well as by keyword, so a search returns the section that answers your question even when it doesn’t contain the exact words. Your team searches from the command palette; Claude and ChatGPT search the same way through the connector and get a link back to the source.' },
  { q: 'Do I need to run anything extra for that?', a: 'Only if you self-host, and only for meaning-based search — you point tela at an embedding model (the hosted instance is already set up). Keyword search always works on its own.' },
  { q: 'Is it really markdown, with all that block editing?', a: 'Yes. The editor is full block editing — drag, slash menu, turn-into, tables, diagrams — but pages.body is plain markdown. There is no block table; reordering a block reorders markdown lines. Import a directory, export anytime.' },
  { q: 'Can I edit in my own editor — Obsidian, VS Code?', a: 'Yes. Mount a space as a local folder over WebDAV and sync it with rclone, then edit the files in any editor you like. Pages round-trip as plain markdown and non-markdown files (images, PDFs, diagrams) sync too — so your local folder and tela stay in step both ways.' },
  { q: 'How do agents sign in?', a: 'Through the Claude and ChatGPT connectors they sign in once with OAuth — no token to handle. For code agents like Claude Code or Cursor, you create an access key that’s scoped to read or write, can expire, and can be limited to a single space.' },
  { q: 'Is my team’s data access-controlled?', a: 'Yes — SSO, organizations and groups, and per-space roles (owner / editor / viewer) with hard invariants. Keys are scoped and audited. The access model is documented and open.' },
  { q: 'Can I self-host it?', a: 'Yes. It’s open and self-hostable with Docker Compose (Postgres, plus an optional embedder for semantic search). Your data on your disk, your markdown exportable. Self-host is the option, not the requirement — the hosted instance is ready to use now.' },
];
---
<section class="section section--tight">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Questions</p>
    <h2 class="h2">Straight answers.</h2>
  </div>
  <div class="faq reveal-up">
    {qs.map((item, i) => (
      <details class="qa" open={i === 0}>
        <summary class="q">
          <span>{item.q}</span>
          <svg class="chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="a">{item.a}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq { border-top: 1px solid var(--border); max-width: 52rem; }
  .qa { border-bottom: 1px solid var(--border); }
  .q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0.25rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
  }
  .q::-webkit-details-marker { display: none; }
  .chev { color: var(--fg-faint); flex: none; transition: transform var(--dur) var(--ease-out); }
  .qa[open] .chev { transform: rotate(180deg); }
  .a {
    padding: 0 0.25rem 1.25rem;
    max-width: var(--measure);
    color: var(--fg-soft);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }
  @media (prefers-reduced-motion: reduce) { .chev { transition: none; } }
</style>
