---
// §11 — FAQ. Question-led, answer-first prose. Native <details> (keyboard-accessible,
// no JS). No FAQPage schema (rich results retired 2026).
const qs = [
  { q: 'Is the MCP integration real or a demo?', a: 'Real. tela-mcp is published on npm with 17 tools over the live REST API. The full tool catalog and the .mcp.json config are in mcp/README.md, and the code is open.' },
  { q: 'Do I need Postgres or Elasticsearch?', a: 'No. Storage and full-text search are both SQLite + FTS5 inside the single Go binary. The only services in the stack are the backend, the frontend, and a Caddy proxy.' },
  { q: 'Can I get my content out?', a: 'Yes. Pages are canonical plain markdown. Bulk-import a directory and export anytime; there’s no proprietary format to convert away from.' },
  { q: 'How do agents authenticate?', a: 'Each agent uses a scoped personal access token (tela_pat_…) issued in Settings → API Keys. Keys are read, write, or admin, and can be pinned to a single space.' },
  { q: 'Is it multiplayer?', a: 'Yes — live collaborative editing over Yjs, with concurrent cursors and edits rebased onto the markdown on save.' },
  { q: 'How is this different from Notion or Confluence?', a: 'Your data is plain markdown on your own server, and agents get a real read/write API through a built-in MCP server — not a chat sidebar bolted onto a closed document store.' },
];
---
<section class="section section--tight">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Questions</p>
    <h2 class="h2">Straight answers.</h2>
  </div>
  <div class="faq reveal-up">
    {qs.map((item, i) => (
      <details class="qa" open={i === 0}>
        <summary class="q">
          <span>{item.q}</span>
          <svg class="chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <p class="a">{item.a}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq { border-top: 1px solid var(--border); max-width: 52rem; }
  .qa { border-bottom: 1px solid var(--border); }
  .q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0.25rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
  }
  .q::-webkit-details-marker { display: none; }
  .chev { color: var(--fg-faint); flex: none; transition: transform var(--dur) var(--ease-out); }
  .qa[open] .chev { transform: rotate(180deg); }
  .a {
    padding: 0 0.25rem 1.25rem;
    max-width: var(--measure);
    color: var(--fg-soft);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }
  @media (prefers-reduced-motion: reduce) { .chev { transition: none; } }
</style>
