---
// Pricing — plans for a personal account and for an organization. Mirrors the
// product's tiers (backend plans table). Honest + low-hype: every plan ships the
// whole product; tiers only change the limits — spaces, storage, members, and the
// monthly AI-answer allowance. Indigo is earned on the one recommended org tier.
// Numbers (incl. AI answers/month) mirror the backend plans table; keep in sync.
const includes = [
  'Semantic search + ask your docs, with citations',
  'MCP connector for Claude & ChatGPT',
  'Local folder sync over WebDAV',
  'Real-time multiplayer editing',
  'SSO, organizations & per-space roles',
  'Plain markdown you own — export anytime',
];

// action drives the CTA wiring (no self-serve billing yet):
//  'app'     → straight to the hosted instance (free signup)
//  'trial'   → opens the early-access dialog (start free now, upgrade by email)
//  'contact' → mailto for sales / enterprise
const CONTACT_EMAIL = 'tela@cagdas.io';

const personal = [
  {
    name: 'Free',
    price: '$0',
    period: 'free forever',
    blurb: 'Personal notes and trying tela.',
    specs: ['3 spaces', '100 pages / space', '100 MB storage', '50 AI answers / month'],
    cta: 'Get started',
    href: 'https://tela.cagdas.io/register',
    action: 'app',
    featured: false,
  },
  {
    name: 'Plus',
    price: '$8',
    period: 'per month',
    blurb: 'For power users who live in their wiki.',
    specs: ['25 spaces', '1,000 pages / space', '5 GB storage', '1,000 AI answers / month'],
    cta: 'Get started',
    href: 'https://tela.cagdas.io/register',
    action: 'trial',
    featured: false,
  },
];

const org = [
  {
    name: 'Free',
    price: '$0',
    period: 'up to 5 members',
    blurb: 'A small team getting started.',
    specs: ['10 spaces', '500 pages / space', '1 GB storage', '5 members', '50 AI answers / month'],
    cta: 'Get started',
    href: 'https://tela.cagdas.io/register',
    action: 'app',
    featured: false,
  },
  {
    name: 'Team',
    price: '$6',
    period: 'per member / month',
    blurb: 'A growing team that runs on its docs.',
    specs: ['100 spaces', 'Unlimited pages', '50 GB storage', '50 members', '2,000 AI answers / month'],
    cta: 'Get started',
    href: 'https://tela.cagdas.io/register',
    action: 'trial',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: "let's talk",
    blurb: 'SSO, audit, and scale for a big team.',
    specs: ['Unlimited spaces', 'Unlimited pages', 'Unlimited storage', 'Unlimited members', 'Unlimited AI'],
    cta: 'Get in touch',
    href: `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('tela Enterprise')}`,
    action: 'contact',
    featured: false,
  },
];
---
<section id="pricing" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Pricing</p>
    <h2 class="h2">Simple plans. Your markdown either way.</h2>
    <p class="lede">
      A personal account and every organization carry their own tier. Tiers only change the
      limits — spaces, storage, and how many AI answers a month — while
      <strong>the wiki, the search, and the agent connector are the same on every plan</strong>.
    </p>
    <p class="trial-note">
      <span class="trial-dot"></span>
      Every new account starts on a <strong>30-day Plus trial</strong> — full AI limits, no card.
    </p>
  </div>

  <div class="tiers tiers--duo reveal-up">
    <p class="tier-group-label">Personal</p>
    <div class="grid grid-2">
      {personal.map((p) => (
        <article class={`price-card${p.featured ? ' price-card--featured' : ''}`}>
          <header class="price-head">
            <h3 class="price-name">{p.name}</h3>
            {p.featured ? <span class="price-tag">Recommended</span> : null}
          </header>
          <p class="price-amount">{p.price}<span class="price-period">{p.period}</span></p>
          <p class="price-blurb">{p.blurb}</p>
          <ul class="price-specs">
            {p.specs.map((s) => <li>{s}</li>)}
          </ul>
          {p.action === 'contact' ? (
            <a href={p.href} class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}>{p.cta}</a>
          ) : (
            <a
              href={p.href}
              class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}
              target="_blank"
              rel="noopener"
              data-plan-cta={p.action === 'trial' ? p.name : undefined}
            >{p.cta}</a>
          )}
        </article>
      ))}
    </div>
  </div>

  <div class="tiers reveal-up">
    <p class="tier-group-label">Organization</p>
    <div class="grid grid-3">
      {org.map((p) => (
        <article class={`price-card${p.featured ? ' price-card--featured' : ''}`}>
          <header class="price-head">
            <h3 class="price-name">{p.name}</h3>
            {p.featured ? <span class="price-tag">Recommended</span> : null}
          </header>
          <p class="price-amount">{p.price}<span class="price-period">{p.period}</span></p>
          <p class="price-blurb">{p.blurb}</p>
          <ul class="price-specs">
            {p.specs.map((s) => <li>{s}</li>)}
          </ul>
          {p.action === 'contact' ? (
            <a href={p.href} class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}>{p.cta}</a>
          ) : (
            <a
              href={p.href}
              class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}
              target="_blank"
              rel="noopener"
              data-plan-cta={p.action === 'trial' ? p.name : undefined}
            >{p.cta}</a>
          )}
        </article>
      ))}
    </div>
  </div>

  <div class="includes reveal-up">
    <p class="includes-label">Every plan includes</p>
    <ul class="includes-grid">
      {includes.map((f) => (
        <li>
          <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="selfhost reveal-up">
    <div class="selfhost-copy">
      <p class="selfhost-label">Or run it yourself</p>
      <p class="selfhost-text">
        tela is open source and self-hostable — Docker Compose, your Postgres, your disk,
        your markdown. No seats to buy and no limits but the ones you set.
      </p>
    </div>
    <a href="https://github.com/zcag/tela" class="selfhost-cta" target="_blank" rel="noopener">
      Self-host it <span class="arr" aria-hidden="true">→</span>
    </a>
  </div>

  {/* Paid-plan CTA dialog — there's no self-serve checkout yet, so a paid CTA
      explains the honest path (start free now, upgrade by email) instead of
      silently dropping you into a free signup. Progressive enhancement: the
      CTAs are real <a href> links to the app, intercepted only when <dialog>
      is supported — JS off / unsupported still reaches the hosted instance. */}
  <dialog id="trial-dialog" class="trial-dialog" aria-labelledby="trial-dialog-title">
    <div class="trial-dialog-inner">
      <button type="button" class="trial-dialog-close" data-close aria-label="Close">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <p class="kicker"><span class="kicker-dot"></span><span data-plan-label>Plus</span> plan</p>
      <h3 id="trial-dialog-title" class="trial-dialog-title">Start free, upgrade when you're ready</h3>
      <p class="trial-dialog-body">
        Self-serve billing isn't live during early access. Every new account starts on a
        <strong>30-day Plus trial</strong> — full AI limits, no card — so you can get going right
        now. When you're ready to move to a paid plan, drop us a line and we'll set it up.
      </p>
      <div class="trial-dialog-actions">
        <a href="https://tela.cagdas.io/register" class="price-cta price-cta--primary" target="_blank" rel="noopener">Start free →</a>
        <a href="mailto:tela@cagdas.io?subject=tela%20paid%20plan" class="price-cta">Email us</a>
      </div>
    </div>
  </dialog>
</section>

<script is:inline>
  (function () {
    var dlg = document.getElementById('trial-dialog');
    // No native <dialog> → leave the CTAs as plain links to the hosted instance.
    if (!dlg || typeof dlg.showModal !== 'function') return;
    var labels = dlg.querySelectorAll('[data-plan-label]');
    document.querySelectorAll('[data-plan-cta]').forEach(function (cta) {
      cta.addEventListener('click', function (e) {
        e.preventDefault();
        var name = cta.getAttribute('data-plan-cta') || 'Plus';
        labels.forEach(function (el) { el.textContent = name; });
        dlg.showModal();
      });
    });
    dlg.querySelectorAll('[data-close]').forEach(function (el) {
      el.addEventListener('click', function () { dlg.close(); });
    });
    // Click the backdrop (outside the inner card) to dismiss.
    dlg.addEventListener('click', function (e) {
      if (e.target === dlg) dlg.close();
    });
  })();
</script>

<style>
  .trial-note {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.4rem 0.8rem 0.4rem 0.7rem;
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-full);
    background: var(--brand-wash);
    font-size: var(--text-sm);
    color: var(--fg-soft);
  }
  .trial-note strong { color: var(--fg); font-weight: 600; }
  .trial-dot {
    width: 6px; height: 6px;
    border-radius: var(--radius-full);
    background: var(--brand);
    box-shadow: var(--glow-brand);
    flex: none;
  }

  .tiers { margin-bottom: 2.5rem; }
  .tiers:last-of-type { margin-bottom: 0; }

  .tier-group-label {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
  }

  .grid { display: grid; gap: 1rem; }
  .grid-2 { grid-template-columns: repeat(2, 1fr); }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }

  /* The Personal tier has only two cards. Left at full width they balloon
     ~50% wider than the three Organization cards below and the CTAs stretch
     into long bars. Cap the grid to two Organization-column widths so the two
     cards match the org cards and align under the first two columns — one
     consistent rhythm across both sections. Only while org is 3-up (≥901px);
     below that both stacks collapse and full width is correct. */
  @media (min-width: 901px) {
    .tiers--duo .grid-2 { max-width: calc((100% - 2rem) / 3 * 2 + 1rem); }
  }

  .price-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  /* Indigo earned on the one recommended tier. */
  .price-card--featured {
    border-color: var(--pill-border);
    background: var(--brand-wash);
    box-shadow: var(--shadow-frame, none);
  }

  .price-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .price-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .price-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-strong);
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }

  .price-amount {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .price-period {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: normal;
    color: var(--fg-faint);
  }

  .price-blurb {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }

  .price-specs {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .price-specs li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    padding-left: 1.1rem;
    position: relative;
  }
  .price-specs li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--brand);
  }

  .price-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .price-cta:hover { border-color: var(--brand); background: var(--surface); }
  .price-cta--primary {
    background: var(--cta-bg);
    border-color: transparent;
    color: var(--cta-fg);
  }
  .price-cta--primary:hover { background: var(--cta-bg-hover); }

  /* Paid-plan dialog */
  .trial-dialog {
    /* Tailwind preflight zeroes dialog margin (kills UA centering) — re-center. */
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
    width: min(30rem, calc(100vw - 2 * var(--space-gutter)));
    padding: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--fg);
    box-shadow: var(--shadow-pop);
  }
  .trial-dialog::backdrop {
    background: var(--scrim);
    backdrop-filter: blur(2px);
  }
  .trial-dialog-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.75rem;
  }
  .trial-dialog .kicker { margin: 0; }
  .trial-dialog-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .trial-dialog-body {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .trial-dialog-body strong { color: var(--fg); font-weight: 600; }
  .trial-dialog-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.35rem;
  }
  .trial-dialog-actions .price-cta { margin-top: 0; }
  .trial-dialog-close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--fg-faint);
    cursor: pointer;
    transition: color var(--dur) var(--ease-out), border-color var(--dur) var(--ease-out);
  }
  .trial-dialog-close:hover { color: var(--fg); border-color: var(--border-strong); }

  .includes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-sunk);
  }
  .includes-label {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
  }
  .includes-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem 1.5rem;
  }
  .includes-grid li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--fg-soft);
  }
  .includes-grid .tick {
    color: var(--brand);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .selfhost {
    margin-top: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .selfhost-copy { max-width: 60ch; }
  .selfhost-label {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .selfhost-text {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .selfhost-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .selfhost-cta:hover { border-color: var(--brand); background: var(--surface-sunk); }
  .selfhost-cta .arr { transition: transform var(--dur) var(--ease-out); }
  .selfhost-cta:hover .arr { transform: translateX(3px); }

  @media (max-width: 900px) {
    .includes-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 620px) {
    .includes-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 900px) {
    .grid-3 { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 620px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
  }
</style>
