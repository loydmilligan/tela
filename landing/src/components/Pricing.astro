---
// Pricing — the cloud ladder. One unified per-seat ladder (Free → Personal → Team →
// Enterprise), not a split personal/org grid. Honest + low-hype: every plan ships the
// whole product; paid tiers raise the metered AI (Atlas sources + monthly answers) and
// add team/enterprise controls — NOT page/space/storage caps. Managed AI is included on
// every cloud plan; self-host is BYO AI and lives on the dedicated /pricing detail.
// Indigo is earned on the one recommended Team tier + the Atlas flagship band.
// Numbers (AI answers/month + Atlas sources + dollars) mirror docs/editions-and-pricing.md
// and the backend plans table — keep in sync.
//
// Props: selfHostLink — where the "run it yourself" callout points (default: the
// editions detail on /pricing). On the standalone /pricing page it's an in-page anchor.
const { selfHostLink = '/pricing#self-host' } = Astro.props;

const includes = [
  'Atlas — generate & refresh a cited, coverage-checked wiki from a git repo or Jira project',
  'Semantic search + ask your docs, with citations',
  'MCP connector for Claude & ChatGPT',
  'Local folder sync over WebDAV',
  'Real-time multiplayer editing',
  'Organizations & per-space roles',
  'Plain markdown you own — export anytime',
];

// action drives the CTA wiring (self-serve billing is live via Polar):
//  'app'     → free signup on the hosted instance (Free tier)
//  'buy'     → the in-app upgrade/checkout page (login-gated; bounces to login
//              then lands on Plan & Usage where checkout is one click)
//  'contact' → mailto for sales / enterprise
const CONTACT_EMAIL = 'tela@telawiki.com';
const REGISTER_URL = 'https://telawiki.com/register';
const UPGRADE_URL = 'https://telawiki.com/settings?tab=billing';

// Yearly is the DEFAULT cadence: the headline number is the per-MONTH equivalent of the
// annual price, with "billed annually" + the full yearly figure on the save line.
// Personal $72/yr → $6/mo (25% off, save $24). Team $96/seat/yr → $8/mo (save $24/seat).
// Free and Enterprise have no yearly option (priceYearMo: null) — the toggle leaves them.
const cloud = [
  {
    name: 'Free',
    price: '$0',
    period: 'free forever',
    priceYearMo: null,
    periodYear: null,
    saveYear: null,
    blurb: 'Personal notes and trying tela.',
    specs: ['1 Atlas source', '50 AI answers / month', 'Unlimited pages & spaces', 'The whole wiki, sheets, decks & sync'],
    cta: 'Get started',
    href: REGISTER_URL,
    action: 'app',
    featured: false,
  },
  {
    name: 'Personal',
    price: '$8',
    period: 'per month',
    priceYearMo: '$6',
    periodYear: '/mo',
    saveYear: 'Billed annually — $72/yr, save $24',
    blurb: 'For power users who live in their wiki.',
    specs: ['5 Atlas sources', '1,000 AI answers / month', 'Custom domain & public spaces', 'Everything in Free'],
    cta: 'Get Personal',
    href: UPGRADE_URL,
    action: 'buy',
    featured: false,
  },
  {
    name: 'Team',
    price: '$10',
    period: 'per seat / month',
    priceYearMo: '$8',
    periodYear: 'per seat / mo',
    saveYear: 'Billed annually — $96/seat/yr, save $24',
    blurb: 'A team that runs on its docs.',
    specs: ['20 Atlas sources', '2,000 AI answers / month, pooled', 'Roles & member management', 'Everything in Personal'],
    cta: 'Get Team',
    href: UPGRADE_URL,
    action: 'buy',
    featured: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: "let's talk",
    priceYearMo: null,
    periodYear: null,
    saveYear: null,
    blurb: 'SSO, audit, and scale for a big team.',
    specs: ['Unlimited Atlas & AI', 'SSO, SCIM & audit log', 'Advanced roles & governance', 'Priority support + SLA'],
    cta: 'Get in touch',
    href: `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('tela Enterprise')}`,
    action: 'contact',
    featured: false,
  },
];
---
<section id="pricing" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Pricing</p>
    <h2 class="h2">Simple plans. Your markdown either way.</h2>
    <p class="lede">
      One ladder, the whole product on every tier — <strong>Atlas, semantic search, ask-your-docs, and the agent connector</strong>.
      Paid tiers raise your AI — how many sources Atlas keeps fresh and how many answers a month — and add team controls.
      Managed AI is included on every cloud plan.
    </p>
  </div>

  <div class="atlas-band reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Flagship</p>
    <p class="atlas-band-text">
      <strong>Atlas is on every plan</strong> — point it at a git repo or Jira project and it
      writes a cited, coverage-checked wiki and keeps it fresh. Paid tiers raise how much you
      can generate.
    </p>
  </div>

  {/* Monthly/Yearly toggle — sits directly above the cards so it reads as part
      of the ladder, not a stray control. Yearly is the DEFAULT (prices show the
      per-month equivalent, billed annually). Progressive enhancement: hidden
      until the inline script wires it — no-JS still sees the default yearly
      prices, so there's no dead control and no mismatch. */}
  <div class="billing-toggle reveal-up" role="tablist" aria-label="Billing period" hidden>
    <div class="billing-seg">
      <button type="button" class="billing-opt" data-period="month" role="tab" aria-selected="false">Monthly</button>
      <button type="button" class="billing-opt is-active" data-period="year" role="tab" aria-selected="true">Yearly</button>
    </div>
    <span class="billing-save">Save up to 25%</span>
  </div>

  <div class="tiers reveal-up">
    <div class="grid grid-4">
      {cloud.map((p) => (
        <article class={`price-card${p.featured ? ' price-card--featured' : ''}`}>
          <header class="price-head">
            <h3 class="price-name">{p.name}</h3>
            {p.featured ? <span class="price-tag">Recommended</span> : null}
          </header>
          <p class="price-amount">
            <span class="price-amt" data-amt-month={p.price} data-amt-year={p.priceYearMo ?? p.price}>{p.priceYearMo ?? p.price}</span>
            <span class="price-period" data-per-month={p.period} data-per-year={p.periodYear ?? p.period}>{p.periodYear ?? p.period}</span>
          </p>
          {p.saveYear ? <p class="price-save" data-save>{p.saveYear}</p> : null}
          <p class="price-blurb">{p.blurb}</p>
          <ul class="price-specs">
            {p.specs.map((s) => <li>{s}</li>)}
          </ul>
          {p.action === 'contact' ? (
            <a href={p.href} class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}>{p.cta}</a>
          ) : (
            <a
              href={p.action === 'buy' ? `${p.href}&interval=year` : p.href}
              class={p.featured ? 'price-cta price-cta--primary' : 'price-cta'}
              target="_blank"
              rel="noopener"
              data-buy-cta={p.action === 'buy' ? '' : undefined}
              data-href-base={p.action === 'buy' ? p.href : undefined}
            >{p.cta}</a>
          )}
        </article>
      ))}
    </div>
  </div>

  <p class="trial-foot reveal-up">
    No card to start — every new account gets a 30-day Personal trial, then settles onto your plan.
  </p>

  <div class="includes reveal-up">
    <p class="includes-label">Every plan includes</p>
    <ul class="includes-grid">
      {includes.map((f) => (
        <li>
          <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="selfhost reveal-up">
    <div class="selfhost-copy">
      <p class="selfhost-label">Or run it yourself — free</p>
      <p class="selfhost-text">
        tela is open source (AGPL). Self-host the whole product — Atlas, search, agents, sync —
        and bring your own AI. Community is free forever; Enterprise adds SSO, audit and governance.
      </p>
    </div>
    <a href={selfHostLink} class="selfhost-cta">
      Compare editions <span class="arr" aria-hidden="true">→</span>
    </a>
  </div>

</section>

<script is:inline>
  (function () {
    var sec = document.getElementById('pricing');
    var toggle = sec && sec.querySelector('.billing-toggle');
    if (!toggle) return;
    toggle.hidden = false; // reveal only with JS — no dead control for no-JS users
    var opts = toggle.querySelectorAll('.billing-opt');
    function apply(period) {
      sec.querySelectorAll('.price-amt').forEach(function (el) {
        el.textContent = el.getAttribute('data-amt-' + period);
      });
      sec.querySelectorAll('.price-period').forEach(function (el) {
        el.textContent = el.getAttribute('data-per-' + period);
      });
      sec.querySelectorAll('[data-save]').forEach(function (el) {
        el.hidden = period !== 'year';
      });
      // Carry the cadence to the app so a yearly click lands on yearly checkout.
      sec.querySelectorAll('[data-buy-cta]').forEach(function (a) {
        var base = a.getAttribute('data-href-base');
        a.href = period === 'year' ? base + '&interval=year' : base;
      });
      opts.forEach(function (b) {
        var on = b.getAttribute('data-period') === period;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }
    opts.forEach(function (b) {
      b.addEventListener('click', function () {
        var period = b.getAttribute('data-period');
        apply(period);
        if (window.umami) window.umami.track('pricing-period-toggle', { period: period });
      });
    });
    // Track plan CTA clicks, injecting the current billing period at click time.
    sec.querySelectorAll('.price-cta').forEach(function (a) {
      a.addEventListener('click', function () {
        var card = a.closest('.price-card');
        var plan = card ? card.querySelector('.price-name') : null;
        var activePeriod = toggle.querySelector('.billing-opt.is-active');
        if (window.umami) window.umami.track('pricing-cta', {
          plan: plan ? plan.textContent.trim().toLowerCase() : 'unknown',
          period: activePeriod ? activePeriod.getAttribute('data-period') : 'year',
        });
      });
    });
    apply('year'); // yearly is the default cadence — sync prices, hrefs, and state
  })();
</script>

<style>
  /* Trial reassurance, deliberately quiet fine-print under the tiers — the trial
     is a perk, not the headline. Purchase (the plan CTAs) leads; this reassures. */
  .trial-foot {
    margin: 1.75rem 0 0;
    text-align: center;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }

  /* Atlas flagship band — leads the plan ladder. Carries the section's one
     earned indigo accent (the brand bar) so Atlas reads as the headline, without
     out-shouting the recommended Team card below. */
  .atlas-band {
    margin: 2rem 0 1.75rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--pill-border);
    border-left: 2px solid var(--brand);
    border-radius: var(--radius-lg);
    background: var(--brand-wash);
  }
  .atlas-band .kicker { margin: 0 0 0.5rem; }
  .atlas-band-text {
    margin: 0;
    max-width: 70ch;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .atlas-band-text strong { color: var(--fg); font-weight: 600; }

  /* Monthly/Yearly segmented toggle — sits right above the cards as one tidy
     unit (segment + savings), so it reads as part of the plan ladder. */
  .billing-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin: 0 0 1.5rem;
  }
  .billing-seg {
    display: inline-flex;
    padding: 0.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    background: var(--surface-sunk);
  }
  .billing-opt {
    appearance: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem 1.1rem;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--fg-soft);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: background var(--dur) var(--ease-out), color var(--dur) var(--ease-out);
  }
  .billing-opt:hover { color: var(--fg); }
  .billing-opt.is-active {
    background: var(--surface);
    color: var(--fg);
    box-shadow: var(--shadow-card);
  }
  .billing-save {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-strong);
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-full);
    background: var(--brand-wash);
    padding: 0.25rem 0.6rem;
    white-space: nowrap;
  }
  .price-save {
    margin: -0.3rem 0 0;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--brand-strong);
  }

  .tiers { margin-bottom: 0; }

  .grid { display: grid; gap: 1rem; }
  .grid-4 { grid-template-columns: repeat(4, 1fr); }

  .price-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  /* Indigo earned on the one recommended tier. */
  .price-card--featured {
    border-color: var(--pill-border);
    background: var(--brand-wash);
    box-shadow: var(--shadow-frame, none);
  }

  .price-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .price-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .price-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-strong);
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }

  .price-amount {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .price-period {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: normal;
    color: var(--fg-faint);
  }

  .price-blurb {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }

  .price-specs {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .price-specs li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    padding-left: 1.1rem;
    position: relative;
  }
  .price-specs li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--brand);
  }

  .price-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .price-cta:hover { border-color: var(--brand); background: var(--surface); }
  .price-cta--primary {
    background: var(--cta-bg);
    border-color: transparent;
    color: var(--cta-fg);
  }
  .price-cta--primary:hover { background: var(--cta-bg-hover); }

  .includes {
    margin-top: 2.5rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-sunk);
  }
  .includes-label {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
  }
  .includes-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem 1.5rem;
  }
  .includes-grid li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--fg-soft);
  }
  .includes-grid .tick {
    color: var(--brand);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .selfhost {
    margin-top: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .selfhost-copy { max-width: 60ch; }
  .selfhost-label {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .selfhost-text {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .selfhost-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .selfhost-cta:hover { border-color: var(--brand); background: var(--surface-sunk); }
  .selfhost-cta .arr { transition: transform var(--dur) var(--ease-out); }
  .selfhost-cta:hover .arr { transform: translateX(3px); }

  @media (max-width: 900px) {
    .includes-grid { grid-template-columns: 1fr 1fr; }
    .grid-4 { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 620px) {
    .includes-grid { grid-template-columns: 1fr; }
    .grid-4 { grid-template-columns: 1fr; }
  }
</style>
